<Window x:Class="GoldenISOBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GoldenISOBuilder"
        xmlns:views="clr-namespace:GoldenISOBuilder.Views"
        Title="WinForge" Height="740" Width="1100"
        MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource BG0Brush}"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="5,5,5,5"
                      GlassFrameThickness="0" NonClientFrameEdges="None"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <Grid Grid.Row="0" Background="{DynamicResource BG1Brush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="3" BorderBrush="{DynamicResource LineSoftBrush}"
                    BorderThickness="0,0,0,1"/>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="14,0,0,0">
                <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,8,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource Gold2Color}" Offset="0"/>
                            <GradientStop Color="{DynamicResource Gold3Color}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="W" FontSize="9" FontWeight="Black" Foreground="{DynamicResource BG0Brush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="WinForge" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource FG0Brush}" VerticalAlignment="Center"/>
                <TextBlock Text=" v2.4.8" FontSize="12" FontWeight="Normal"
                           Foreground="{DynamicResource FG2Brush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Breadcrumb -->
            <StackPanel x:Name="BreadcrumbPanel" Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="BreadcrumbHome" Text="Home" FontSize="11.5"
                           Foreground="{DynamicResource FG1Brush}" Visibility="Visible"/>
                <StackPanel x:Name="BreadcrumbWizardPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="New Build" FontSize="11.5" Foreground="{DynamicResource FG1Brush}"/>
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource ChevronRightIcon}"
                          Stroke="{DynamicResource FG3Brush}" StrokeThickness="1.5"
                          Width="11" Height="11" Margin="10,0"/>
                    <TextBlock x:Name="BreadcrumbStepText" Text="Step 1 of 6" FontSize="11.5"
                               FontWeight="Medium" Foreground="{DynamicResource FG0Brush}"/>
                </StackPanel>
                <TextBlock x:Name="BreadcrumbProgress" Visibility="Collapsed" FontSize="11.5"
                           FontWeight="Medium" Foreground="{DynamicResource FG0Brush}"
                           Text="Build Progress"/>
                <TextBlock x:Name="BreadcrumbSettings" Text="Settings" FontSize="11.5"
                           FontWeight="Medium" Foreground="{DynamicResource FG0Brush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource WinControlButtonStyle}" Click="MinimizeButton_Click">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource MinusIcon}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.5" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource XIcon}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.5" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition x:Name="NavPanelColumn" Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== ICON RAIL ===== -->
            <Border Grid.Column="0" Background="{DynamicResource BG1Brush}"
                    BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,10">
                        <Button x:Name="NavHelpBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Help &amp; About" Click="NavHelpBtn_Click">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource HelpIcon}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="NavSettingsBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Settings" Click="NavSettingsBtn_Click" Margin="0,4,0,0">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource SettingsIcon}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  Width="18" Height="18"/>
                        </Button>
                    </StackPanel>

                    <!-- Top buttons -->
                    <StackPanel Margin="8,10,8,0">
                        <Button x:Name="NavHomeBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Home" Click="NavHomeBtn_Click" Tag="active">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource DiscIcon}"
                                  Stroke="{DynamicResource Gold1Brush}"
                                  Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="NavNewBuildBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="New Build" Click="NavNewBuildBtn_Click" Margin="0,4,0,0">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource PlusIcon}"
                                  Stroke="{DynamicResource SourceAccentBrush}"
                                  Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="NavProgressBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Build Progress" Click="NavProgressBtn_Click" Margin="0,4,0,0">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource CpuIcon}"
                                  Stroke="{DynamicResource BuildAccentBrush}"
                                  Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="NavHistoryBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Build History" Margin="0,4,0,0"
                                Click="NavHistoryBtn_Click">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource HistoryIcon}"
                                  Stroke="{DynamicResource InfoBrush}"
                                  Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="NavTestVmBtn" Style="{StaticResource IconRailButtonStyle}"
                                ToolTip="Test in VM" Margin="0,4,0,0"
                                Click="NavTestVmBtn_Click">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource MonitorIcon}"
                                  Stroke="{DynamicResource TestVmAccentBrush}"
                                  Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== NAV PANEL ===== -->
            <Border x:Name="NavPanelBorder" Grid.Column="1" Background="{DynamicResource BG1Brush}"
                    BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Footer: shows current output path + free space on its drive -->
                    <Border x:Name="FooterDriveBar" DockPanel.Dock="Bottom"
                            BorderBrush="{DynamicResource LineSoftBrush}"
                            BorderThickness="0,1,0,0" Padding="12,10"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource HardDriveIcon}"
                                  Stroke="{DynamicResource FG2Brush}" StrokeThickness="1.5"
                                  Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FooterDrivePath" Text="" FontSize="11.5"
                                       Foreground="{DynamicResource FG2Brush}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       MaxWidth="160"/>
                            <TextBlock x:Name="FooterFreeSpace" Text="" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource FG2Brush}"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False">
                        <StackPanel>
                            <!-- Welcome / Quick Access nav -->
                            <StackPanel x:Name="NavWelcomePanel" Visibility="Visible">
                                <TextBlock Text="QUICK ACCESS" Margin="16,14,16,10"
                                           Style="{StaticResource EyebrowText}"/>
                                <StackPanel Margin="8,0,8,0">
                                    <Button x:Name="NavQuickHomeBtn"
                                            Style="{StaticResource WizardStepButtonStyle}"
                                            FocusVisualStyle="{x:Null}"
                                            Tag="active" Click="NavQuickHomeBtn_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{DynamicResource Gold1Brush}"
                                                    Background="{DynamicResource BG3Brush}" BorderThickness="1"
                                                    HorizontalAlignment="Left">
                                                <Path Style="{StaticResource IconPath}" Data="{StaticResource DiscIcon}"
                                                      Stroke="{DynamicResource Gold1Brush}" Width="12" Height="12"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Home" FontSize="12.5"
                                                       FontWeight="Medium" Foreground="{DynamicResource FG0Brush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="NavQuickProfilesBtn"
                                            Style="{StaticResource WizardStepButtonStyle}"
                                            FocusVisualStyle="{x:Null}"
                                            Margin="0,1,0,0" Click="NavQuickProfilesBtn_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{DynamicResource LineBrush}"
                                                    Background="{DynamicResource BG3Brush}" BorderThickness="1"
                                                    HorizontalAlignment="Left">
                                                <Path Style="{StaticResource IconPath}" Data="{StaticResource FileIcon}"
                                                      Stroke="{DynamicResource FG2Brush}" Width="12" Height="12"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Profiles" FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Saved profiles" FontSize="11"
                                                           Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="NavQuickTemplatesBtn"
                                            Style="{StaticResource WizardStepButtonStyle}"
                                            FocusVisualStyle="{x:Null}"
                                            Margin="0,1,0,0" Click="NavQuickTemplatesBtn_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    BorderBrush="{DynamicResource LineBrush}"
                                                    Background="{DynamicResource BG3Brush}" BorderThickness="1"
                                                    HorizontalAlignment="Left">
                                                <Path Style="{StaticResource IconPath}" Data="{StaticResource FolderIcon}"
                                                      Stroke="{DynamicResource FG2Brush}" Width="12" Height="12"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Templates" FontSize="12.5" FontWeight="Medium"
                                                           Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Starter configs" FontSize="11"
                                                           Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Wizard Steps nav -->
                            <StackPanel x:Name="NavWizardPanel" Visibility="Collapsed">
                                <TextBlock Text="BUILD WIZARD" Margin="16,14,16,10"
                                           Style="{StaticResource EyebrowText}"/>
                                <StackPanel Margin="8,0,8,0">
                                    <!-- Step 1 -->
                                    <Button x:Name="WizardStep1Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S1Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource Gold1Brush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S1Text" Text="1" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Gold1Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Source &amp; Output" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG0Brush}"/>
                                                <TextBlock Text="ISO + working dir" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource DiscIcon}" Stroke="{DynamicResource SourceAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 2 -->
                                    <Button x:Name="WizardStep2Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="1" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S2Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S2Text" Text="2" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Assets" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Wallpaper, drivers, apps" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource BoxIcon}" Stroke="{DynamicResource AssetsAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 3 -->
                                    <Button x:Name="WizardStep3Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="2" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S3Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S3Text" Text="3" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Customizations" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Package removal, security" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource LayersIcon}" Stroke="{DynamicResource CustomAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 4 -->
                                    <Button x:Name="WizardStep4Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="3" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S4Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S4Text" Text="4" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Admin Account" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Credentials" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource UserIcon}" Stroke="{DynamicResource AdminAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 5: Registry -->
                                    <Button x:Name="WizardStepRegistryBtn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="4" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="SRegBadge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="SRegText" Text="5" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Registry Changes" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Registry tweaks" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource ShieldIcon}" Stroke="{DynamicResource RegistryAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 6: Advanced -->
                                    <Button x:Name="WizardStepAdvancedBtn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="5" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="SAdvBadge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="SAdvText" Text="6" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Advanced Options" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Features, OEM, power" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource LayersIcon}" Stroke="{DynamicResource Gold1Brush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 7: Review -->
                                    <Button x:Name="WizardStep5Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="6" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S5Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S5Text" Text="6" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Review" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Pre-flight checks" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource CheckCircleIcon}" Stroke="{DynamicResource ReviewAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <!-- Step 8: Build -->
                                    <Button x:Name="WizardStep6Btn" Style="{StaticResource WizardStepButtonStyle}"
                                            Click="WizardStep_Click" Tag="7" Margin="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border x:Name="S6Badge" Width="22" Height="22" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" Background="{DynamicResource BG3Brush}" BorderThickness="1" HorizontalAlignment="Left">
                                                <TextBlock x:Name="S6Text" Text="7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FG2Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Build" FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource FG1Brush}"/>
                                                <TextBlock Text="Start the build" FontSize="11" Foreground="{DynamicResource FG2Brush}"/>
                                            </StackPanel>
                                            <Path Grid.Column="2" Style="{StaticResource IconPath}" Data="{StaticResource ZapIcon}" Stroke="{DynamicResource BuildAccentBrush}" StrokeThickness="1.5" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Build History (always shown) -->
                            <Border BorderBrush="{DynamicResource LineSoftBrush}"
                                    BorderThickness="0,1,0,0" Margin="0,18,0,0" Padding="0,12,0,8">
                                <StackPanel>
                                    <Grid Margin="16,0,16,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="BUILD HISTORY" Style="{StaticResource EyebrowText}"/>
                                        <Path Grid.Column="1" Style="{StaticResource IconPath}"
                                              Data="{StaticResource SearchIcon}"
                                              Stroke="{DynamicResource FG2Brush}" StrokeThickness="1.5"
                                              Width="12" Height="12"/>
                                    </Grid>
                                    <!-- Build history entries — populated from BuildHistoryStore at runtime -->
                                    <TextBlock x:Name="SidebarHistoryEmpty"
                                               Text="No builds yet" Foreground="{DynamicResource FG3Brush}"
                                               FontSize="11.5" Margin="16,6,16,2" FontStyle="Italic"
                                               Visibility="Visible"/>
                                    <StackPanel x:Name="SidebarHistoryList" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== CANVAS ===== -->
            <Grid Grid.Column="2" Background="{DynamicResource BG0Brush}">
                <views:WelcomePage  x:Name="PageWelcome"  Visibility="Visible"/>
                <views:Step1Page    x:Name="PageStep1"    Visibility="Collapsed"/>
                <views:Step2Page    x:Name="PageStep2"    Visibility="Collapsed"/>
                <views:Step3Page    x:Name="PageStep3"    Visibility="Collapsed"/>
                <views:Step4Page         x:Name="PageStep4"        Visibility="Collapsed"/>
                <views:StepRegistryPage  x:Name="PageStepRegistry"  Visibility="Collapsed"/>
                <views:StepAdvancedPage  x:Name="PageStepAdvanced" Visibility="Collapsed"/>
                <views:Step5Page         x:Name="PageStep5"        Visibility="Collapsed"/>
                <views:Step6Page         x:Name="PageStep6"        Visibility="Collapsed"/>
                <views:SettingsPage x:Name="PageSettings" Visibility="Collapsed"/>
                <views:TestVmPage   x:Name="PageTestVm"   Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>

