<UserControl x:Class="GoldenISOBuilder.Views.Step2Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="ASSETS" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Stage wallpaper, first-boot apps, and deployment scripts"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel h:PanelSpacing.Spacing="20">

                <!-- ══ Wallpaper ══════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Desktop Wallpaper" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="Replaces the default Windows wallpaper in the image"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Drop zone (visible when no wallpaper selected) -->
                            <Border x:Name="WallpaperDropZone" Style="{StaticResource DropZoneStyle}"
                                    AllowDrop="True" Cursor="Hand"
                                    MouseLeftButtonDown="WallpaperDrop_Click"
                                    DragOver="Wallpaper_DragOver" Drop="Wallpaper_Drop">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="24,22,24,22" h:PanelSpacing.Spacing="6">
                                    <Path Style="{StaticResource IconPath}" Width="24" Height="24"
                                          Data="{StaticResource ImageIcon}" Stroke="{DynamicResource FG2Brush}"
                                          HorizontalAlignment="Center"/>
                                    <TextBlock Text="Drop image or click to browse"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- File info row (visible when wallpaper selected) -->
                            <Border x:Name="WallpaperFileRow" Style="{StaticResource FilledDropZoneStyle}"
                                    Visibility="Collapsed" Cursor="Hand"
                                    MouseLeftButtonDown="WallpaperDrop_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Style="{StaticResource IconPath}"
                                          Width="16" Height="16" Data="{StaticResource ImageIcon}"
                                          Stroke="{DynamicResource OkBrush}" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="WallpaperFileLabel" Grid.Column="1"
                                               Foreground="{DynamicResource FG0Brush}" FontSize="13"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="2" Content="✕" Style="{StaticResource GhostButtonStyle}"
                                            FontSize="11" Padding="6,2" Margin="8,0,0,0"
                                            Click="WallpaperClear_Click"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Supported: JPG, PNG, BMP · 1920×1080 or higher recommended"
                                       Style="{StaticResource FieldHintText}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Preview pane -->
                        <Border Grid.Column="1" Background="{DynamicResource BG3Brush}" CornerRadius="8"
                                Width="192" Height="108" VerticalAlignment="Top" ClipToBounds="True">
                            <Grid>
                                <!-- Placeholder -->
                                <StackPanel x:Name="WallpaperPlaceholder"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            h:PanelSpacing.Spacing="6">
                                    <Path Style="{StaticResource IconPath}" Width="28" Height="28"
                                          Data="{StaticResource ImageIcon}" Stroke="{DynamicResource FG3Brush}"/>
                                    <TextBlock Text="Preview" Foreground="{DynamicResource FG3Brush}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Actual preview -->
                                <Image x:Name="WallpaperPreview" Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ══ Windows Updates (auto-fetch — toggled in Settings) ═════════
                     Visible only when EnableAutoFetchFeatures is on. Lets the
                     admin either point at a folder of .msu files (existing
                     pattern) or fetch the current LCU + checkpoint chain +
                     optional 25H2 eKB directly from Microsoft Update Catalog. -->
                <Border x:Name="UpdatesCard" Style="{StaticResource CardStyle}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Windows Updates"
                                           Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="Slipstream the latest cumulative update + checkpoint chain into install.wim so deployed machines don't pull ~4 GB at first boot. Optionally apply the 25H2 enablement package."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <!-- Mode toggle: Auto / Manual -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,8"
                                    h:PanelSpacing.Spacing="6">
                            <RadioButton x:Name="UpdatesAutoMode" Content="Auto-fetch from Microsoft"
                                         GroupName="UpdatesMode" IsChecked="True"
                                         Foreground="{DynamicResource FG0Brush}"
                                         Checked="UpdatesMode_Changed"/>
                            <RadioButton x:Name="UpdatesManualMode" Content="Pick folder of MSU/CAB files"
                                         GroupName="UpdatesMode"
                                         Foreground="{DynamicResource FG0Brush}" Margin="16,0,0,0"
                                         Checked="UpdatesMode_Changed"/>
                        </StackPanel>

                        <!-- Auto-fetch panel -->
                        <StackPanel x:Name="UpdatesAutoPanel">
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="UpdatesDetectedBuild"
                                               Text="ISO not yet analysed — go to Step 1 first."
                                               Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="UpdatesRefreshBtn"
                                        Content="Refresh catalog"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Click="UpdatesRefresh_Click"
                                        Margin="8,0,0,0"/>
                            </Grid>
                            <ComboBox x:Name="UpdatesTargetCombo"
                                      Margin="0,12,0,0" Height="32"
                                      Foreground="{DynamicResource FG0Brush}"
                                      Background="{DynamicResource BG0Brush}"
                                      SelectionChanged="UpdatesTarget_Changed">
                                <ComboBoxItem Content="(no targets available)"/>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                        h:PanelSpacing.Spacing="6">
                                <Button x:Name="UpdatesFetchBtn"
                                        Content="Fetch updates"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        IsEnabled="False"
                                        Click="UpdatesFetch_Click"/>
                                <ProgressBar x:Name="UpdatesProgress" Width="280" Height="6"
                                             Margin="12,0,0,0"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"/>
                            </StackPanel>
                            <TextBlock x:Name="UpdatesStatusText"
                                       Margin="0,8,0,0"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource FG2Brush}"/>
                        </StackPanel>

                        <!-- Manual-folder panel -->
                        <StackPanel x:Name="UpdatesManualPanel" Visibility="Collapsed">
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="UpdatesFolderBox" Grid.Column="0" Height="32"
                                         IsReadOnly="True"
                                         Foreground="{DynamicResource FG0Brush}"
                                         Background="{DynamicResource BG0Brush}"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         Text="No folder selected"/>
                                <Button Grid.Column="1" x:Name="UpdatesBrowseBtn"
                                        Content="Browse folder…" Margin="8,0,0,0"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Click="UpdatesBrowse_Click"/>
                            </Grid>
                            <TextBlock x:Name="UpdatesManualHint"
                                       Margin="0,6,0,0"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource FG2Brush}"
                                       Text="Drop the LCU + every preceding checkpoint CU + (optional) KB5054156 in one folder. DISM auto-resolves the prerequisite chain."
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Resolved package list — shared between Auto and Manual -->
                        <StackPanel x:Name="UpdatesResolvedPanel" Margin="0,12,0,0"
                                    h:PanelSpacing.Spacing="4"/>
                    </StackPanel>
                </Border>

                <!-- ══ Language Pack Injection ═══════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <!-- Header row ──────────────────────────────────────────── -->
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <!-- Title + ⓘ info trigger -->
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Language Pack Injection"
                                               Style="{StaticResource CardTitleText}"/>
                                    <!-- Circular ⓘ badge — hover opens popup, click also opens browser -->
                                    <Border x:Name="LangInfoTrigger"
                                            Width="18" Height="18" CornerRadius="9"
                                            Background="{DynamicResource InfoBrush}"
                                            VerticalAlignment="Center" Cursor="Hand"
                                            MouseEnter="LangInfoTrigger_MouseEnter"
                                            MouseLeave="LangInfoTrigger_MouseLeave">
                                        <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Browse the LP ISO folder — all languages are detected automatically and grouped for easy multi-select."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Content="+ Add Language Pack" Style="{StaticResource GhostButtonStyle}"
                                    FontSize="12" Click="AddLanguagePack_Click"/>
                        </Grid>

                        <!-- ⓘ Hover popup — contains clickable hyperlink ──────────────────
                             StaysOpen=True means WPF won't close it automatically;
                             MouseEnter/Leave on the inner Border controls lifetime.       -->
                        <Popup x:Name="LangInfoPopup"
                               PlacementTarget="{Binding ElementName=LangInfoTrigger}"
                               Placement="Bottom" VerticalOffset="6"
                               StaysOpen="True" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource BG2Brush}"
                                    BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12" MaxWidth="400"
                                    MouseEnter="LangInfoPopup_MouseEnter"
                                    MouseLeave="LangInfoPopup_MouseLeave">
                                <StackPanel h:PanelSpacing.Spacing="8">
                                    <TextBlock Text="Downloading the Windows 11 Language Pack ISO"
                                               Foreground="{DynamicResource FG0Brush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                               Text="Microsoft distributes a Language Pack ISO containing CAB files for every supported language. Each language has up to 6 components: Core LP · Basic · Handwriting · OCR · Speech · TextToSpeech."/>
                                    <TextBlock FontSize="12" TextWrapping="Wrap">
                                        <Run Foreground="{DynamicResource FG2Brush}" Text="Official download guide → "/>
                                        <Hyperlink NavigateUri="https://learn.microsoft.com/en-us/azure/virtual-desktop/windows-11-language-packs"
                                                   RequestNavigate="LangPackLink_RequestNavigate">
                                            <Run Foreground="{DynamicResource InfoBrush}"
                                                 Text="learn.microsoft.com — Windows 11 Language Packs"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <!-- Language scan result panel (visible after folder is selected) ── -->
                        <Border x:Name="LangScanResultPanel" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6"
                                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                Padding="12,10" Margin="0,8,0,0">
                            <StackPanel h:PanelSpacing.Spacing="10">
                                <!-- Source info + toolbar -->
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="LangScanSourceLabel"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                        <TextBlock Foreground="{DynamicResource FG3Brush}" FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Text="All components (Core, Basic, Handwriting, OCR, Speech, TTS) are pre-selected per language."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                VerticalAlignment="Center" h:PanelSpacing.Spacing="6">
                                        <Button Content="All" Style="{StaticResource GhostButtonStyle}"
                                                FontSize="11" Click="LangSelectAll_Click"/>
                                        <Button Content="None" Style="{StaticResource GhostButtonStyle}"
                                                FontSize="11" Click="LangSelectNone_Click"/>
                                        <Button Content="Add Selected →"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                FontSize="11" Padding="10,5"
                                                Click="LangAddSelected_Click"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Language search box -->
                                <Grid>
                                    <TextBox x:Name="LangSearchBox"
                                             Style="{StaticResource TextInputStyle}"
                                             Height="34" Padding="10,0"
                                             TextChanged="LangSearch_TextChanged"/>
                                    <TextBlock x:Name="LangSearchPlaceholder"
                                               Text="🔍  Search languages…"
                                               Foreground="{DynamicResource FG3Brush}"
                                               FontSize="12"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="Visible"/>
                                </Grid>

                                <!-- Scrollable language checkbox list -->
                                <Border Background="{DynamicResource BG1Brush}" CornerRadius="6"
                                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                                    <ScrollViewer Focusable="False" MaxHeight="220"
                                                  VerticalScrollBarVisibility="Auto" Padding="2">
                                        <StackPanel x:Name="LangGroupsPanel" Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Added packs list ────────────────────────────────────── -->
                        <StackPanel x:Name="LangPacksPanel" h:PanelSpacing.Spacing="6" Margin="0,8,0,0"/>

                        <TextBlock x:Name="LangPacksEmptyHint"
                                   Text="No language packs added. Click '+ Add Language Pack' and select the LanguagesAndOptionalFeatures folder from the LP ISO."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12" FontStyle="Italic"/>

                        <!-- Step-by-step guide ──────────────────────────────────── -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6"
                                Padding="14,12" Margin="0,10,0,0">
                            <StackPanel h:PanelSpacing.Spacing="6">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                          Data="{StaticResource AlertIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="How to install language packs"
                                               Foreground="{DynamicResource FG0Brush}"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"
                                           Text="1.  Download the Windows 11 Language Pack ISO from Microsoft (click the ⓘ above for the link). Right-click → Mount it — it will appear as a new drive."/>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"
                                           Text="2.  Click '+ Add Language Pack' and browse to the LanguagesAndOptionalFeatures\ folder inside the mounted drive."/>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"
                                           Text="3.  All detected languages appear as rows. Tick each language you need — Core LP, Basic, Handwriting, OCR, Speech, and TTS are all selected automatically."/>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"
                                           Text="4.  Click 'Add Selected →'. DISM injects them in the correct dependency order during the build (Core LP first, then optional features)."/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ══ Driver Injection ════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Driver Injection" Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="Injects OEM drivers from selected folders into the offline image via DISM /Add-Driver /Recurse"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Content="+ Add Driver Folder" Style="{StaticResource GhostButtonStyle}"
                                    FontSize="12" Click="AddDriverFolder_Click"/>
                        </Grid>

                        <StackPanel x:Name="DriversPanel" h:PanelSpacing.Spacing="6" Margin="0,8,0,0"/>

                        <TextBlock x:Name="DriversEmptyHint"
                                   Text="No driver folders added. Click '+ Add Driver Folder' to inject OEM drivers."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12" FontStyle="Italic"/>

                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                      Data="{StaticResource AlertIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                <TextBlock Text="DISM recursively scans the folder for .INF files. Place each hardware category in its own sub-folder (e.g. Network\, Storage\, Video\)."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ Driver Auto-Fetch (Dell / HP / Lenovo) ════════════════════
                     Visible only when EnableAutoFetchFeatures is on (Settings).
                     Sits next to the manual Driver Injection card above so
                     admins can use both: a vendor pack for the target SKUs and
                     a folder pick for anything else. -->
                <Border x:Name="DriversAutoCard" Style="{StaticResource CardStyle}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Driver Auto-Fetch (Dell / HP / Lenovo)"
                                           Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="Pick laptop / desktop SKUs and the tool downloads the official OEM driver pack from the vendor's public catalogue."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Vendor"
                                       Grid.Column="0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                            <ComboBox x:Name="VendorCombo" Grid.Column="1" Height="32"
                                      Foreground="{DynamicResource FG0Brush}"
                                      Background="{DynamicResource BG0Brush}"
                                      SelectionChanged="Vendor_Changed">
                                <ComboBoxItem Content="Dell"   Tag="Dell"   IsSelected="True"/>
                                <ComboBoxItem Content="HP"     Tag="HP"/>
                                <ComboBoxItem Content="Lenovo" Tag="Lenovo"/>
                            </ComboBox>
                            <Button Grid.Column="2" x:Name="DriverRefreshBtn"
                                    Content="Load models"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Margin="8,0,0,0"
                                    Click="DriverRefresh_Click"/>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Search model"
                                       Grid.Column="0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                            <TextBox x:Name="ModelSearchBox" Grid.Column="1" Height="32"
                                     Foreground="{DynamicResource FG0Brush}"
                                     Background="{DynamicResource BG0Brush}"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ModelSearch_Changed"/>
                        </Grid>

                        <Border Margin="0,8,0,0"
                                Background="{DynamicResource BG0Brush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1" CornerRadius="6"
                                MinHeight="120" MaxHeight="220">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ModelListPanel" Margin="6"/>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    h:PanelSpacing.Spacing="6">
                            <Button x:Name="DriverFetchBtn"
                                    Content="Fetch selected (max 3)"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="False"
                                    Click="DriverFetch_Click"/>
                            <ProgressBar x:Name="DriverProgress" Width="280" Height="6"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         Visibility="Collapsed"/>
                        </StackPanel>
                        <TextBlock x:Name="DriverStatusText"
                                   Margin="0,8,0,0" FontSize="11.5"
                                   Foreground="{DynamicResource FG2Brush}"
                                   TextWrapping="Wrap"/>

                        <StackPanel x:Name="FetchedPacksPanel" Margin="0,8,0,0"
                                    h:PanelSpacing.Spacing="4"/>

                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6"
                                Padding="12,10" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                      Data="{StaticResource AlertIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                <TextBlock Text="Fetched packs are stored under %LOCALAPPDATA%\GoldenISOBuilder\Cache and reused across builds. WinPE-critical drivers (Net/Storage/HID) are auto-injected into boot.wim to unblock Intel 12th-gen+ NVMe."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ First-Boot Applications ════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="First-Boot Applications" Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="These EXE/MSI installers are staged inside the image and installed silently on first login via GIBFirstBoot"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Content="+ Add App" Style="{StaticResource GhostButtonStyle}"
                                    FontSize="12" Click="AddApp_Click"/>
                        </Grid>

                        <!-- Column headers (only visible when list is non-empty) -->
                        <Grid x:Name="AppsHeader" Visibility="Collapsed" Margin="0,12,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="App Name" Style="{StaticResource FieldLabelText}" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Installer File" Style="{StaticResource FieldLabelText}" Margin="0,0,8,0"/>
                            <!-- Silent Args header — inline hint explains format -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                                <TextBlock Text="Silent Args" Style="{StaticResource FieldLabelText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" — space-separated, no commas"
                                           Foreground="{DynamicResource FG3Brush}" FontSize="10"
                                           FontStyle="Italic" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="Type" Style="{StaticResource FieldLabelText}"/>
                        </Grid>

                        <!-- Dynamic apps list -->
                        <StackPanel x:Name="AppsPanel" h:PanelSpacing.Spacing="6"/>

                        <!-- Silent args format reference — visible whenever apps are present -->
                        <Border x:Name="AppsArgsHint" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6"
                                Padding="12,9" Margin="0,8,0,0">
                            <StackPanel h:PanelSpacing.Spacing="4">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="6">
                                    <Path Style="{StaticResource IconPath}" Width="13" Height="13"
                                          Data="{StaticResource AlertIcon}"
                                          Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="Silent Args format — space-separated flags, no commas, no quotes around the whole string"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Foreground="{DynamicResource FG3Brush}" FontSize="11"
                                           FontFamily="Consolas" Margin="19,0,0,0">
                                    <Run Text="MSI:           leave BLANK — /qn /norestart is added automatically." Foreground="{DynamicResource FG1Brush}"/>
                                    <LineBreak/>
                                    <Run Text="MSI extras:    "/><Run Text="REBOOT=ReallySuppress  ALLUSERS=1  ADDLOCAL=…" Foreground="{DynamicResource FG1Brush}"/>
                                    <LineBreak/>
                                    <Run Text="EXE:           "/><Run Text="/S      (NSIS / Inno Setup — default)" Foreground="{DynamicResource FG1Brush}"/>
                                    <LineBreak/>
                                    <Run Text="EXE (others):  "/><Run Text="/silent  /VERYSILENT  /quiet  /norestart" Foreground="{DynamicResource FG1Brush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <TextBlock x:Name="AppsEmptyHint"
                                   Text="No applications added yet. Click '+ Add App' to stage installers."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12"
                                   FontStyle="Italic" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ══ Staged Image Files ═══════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Staged Image Files" Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="Copy files to any folder inside the image — Public Desktop, System32, ProgramData, etc."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Content="+ Add File" Style="{StaticResource GhostButtonStyle}"
                                    FontSize="12" Click="AddStagedFile_Click"/>
                        </Grid>

                        <!-- Column headers — only visible when there are staged files -->
                        <Grid x:Name="StagedFilesHeader" Margin="22,6,10,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Source File"
                                       FontSize="11" Foreground="{DynamicResource FG3Brush}"/>
                            <TextBlock Grid.Column="2" Text="Destination folder (inside image)"
                                       FontSize="11" Foreground="{DynamicResource FG3Brush}"/>
                        </Grid>

                        <StackPanel x:Name="PublicFilesPanel" h:PanelSpacing.Spacing="6" Margin="0,4,0,0"/>

                        <TextBlock x:Name="PublicFilesEmptyHint"
                                   Text="No files added. Click '+ Add File' to stage files into any folder in the image."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- ══ Deployment Scripts ══════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Header with toggle and Add button -->
                        <Grid Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Deployment Scripts" Style="{StaticResource CardTitleText}"/>
                                <TextBlock Text="Scripts copied to C:\Users\Public\Documents in the image and available on first login"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" h:PanelSpacing.Spacing="10">
                                <Button Content="+ Add Script" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Click="AddDeploymentScript_Click"/>
                                <CheckBox x:Name="IncludeDeploymentToggle" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          Checked="DeploymentToggle_Changed" Unchecked="DeploymentToggle_Changed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Script list (collapsed when toggle is off) -->
                        <StackPanel x:Name="DeploymentScriptsPanel" Margin="0,12,0,0" h:PanelSpacing.Spacing="6"/>

                        <!-- Bug fix: Collapsed by default — OnLoaded sets correct state -->
                        <TextBlock x:Name="DeploymentScriptsEmptyHint"
                                   Text="No scripts added. Click '+ Add Script' to stage files into the image."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12"
                                   FontStyle="Italic" Margin="0,10,0,0"
                                   Visibility="Collapsed"/>

                        <!-- Info note — named so code-behind can hide it when toggle is off -->
                        <Border x:Name="DeploymentScriptsInfoNote"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,10"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                      Data="{StaticResource AlertIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                <TextBlock Text="Scripts are copied to C:\Users\Public\Documents. You can call them from SetupComplete.cmd or run them manually on first login."
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Height="24"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 2 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Continue →" Style="{StaticResource PrimaryButtonStyle}"
                            Click="Continue_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
