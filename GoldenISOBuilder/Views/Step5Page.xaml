<UserControl x:Class="GoldenISOBuilder.Views.Step5Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="REVIEW" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Confirm your build configuration before starting"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel h:PanelSpacing.Spacing="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Source & Output -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                          Data="{StaticResource DiscIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="Source &amp; Output" Style="{StaticResource CardTitleText}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Padding="8,4" Click="EditStep1_Click"
                                        Content="Edit"/>
                            </Grid>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid><TextBlock Text="ISO Source" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_IsoSource" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="280"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Edition" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Edition" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Architecture" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Arch" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Output Folder" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Output" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="280"/></Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Assets -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                          Data="{StaticResource BoxIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="Assets" Style="{StaticResource CardTitleText}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Padding="8,4" Click="EditStep2_Click" Content="Edit"/>
                            </Grid>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid><TextBlock Text="Wallpaper" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Wallpaper" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="240"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Applications staged" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Apps" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Staged image files" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_PublicFiles" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Deployment scripts" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Keyboard" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Language packs" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_LangPacks" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Driver folders" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Drivers" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Auto-fetched driver packs" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_AutoDrivers" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="360"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Windows Updates (slipstream)" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_AutoUpdates" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Customizations -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,20,10,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                          Data="{StaticResource SettingsIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="Customizations" Style="{StaticResource CardTitleText}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Padding="8,4" Click="EditStep3_Click" Content="Edit"/>
                            </Grid>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid><TextBlock Text="Bloatware to remove" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Bloat" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Group policies" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_GroupPolicies" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Disable SMBv1" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Smb1" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Disable Telemetry" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Telemetry" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Dark Mode" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_DarkMode" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="BitLocker" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_BitLocker" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12" TextWrapping="Wrap" MaxWidth="260"/></Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Admin -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,20,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                          Data="{StaticResource UserIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                    <TextBlock Text="Admin Account" Style="{StaticResource CardTitleText}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Padding="8,4" Click="EditStep4_Click" Content="Edit"/>
                            </Grid>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid><TextBlock Text="Username" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_AdminUser" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Password" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_AdminPwd" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Auto-Login" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_AutoLogin" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Computer Prefix" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Prefix" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Registry + Advanced -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,20,10,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Registry &amp; Features" Style="{StaticResource CardTitleText}"/>
                            </Grid>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid><TextBlock Text="Custom registry entries" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_RegEntries" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <!-- Features list can be long — stacked layout prevents the value
                                     overflowing left and obscuring the label in a column-less Grid. -->
                                <StackPanel>
                                    <TextBlock Text="Features to enable / disable" Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="V_Features" Foreground="{DynamicResource FG0Brush}" FontSize="12"
                                               TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid><TextBlock Text="Power Plan" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                      <TextBlock x:Name="V_Power" HorizontalAlignment="Right" Foreground="{DynamicResource FG0Brush}" FontSize="12"/></Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Pre-Flight Checks -->
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Pre-Flight Checks" Style="{StaticResource CardTitleText}" Margin="0,0,0,12"/>
                            <StackPanel x:Name="PreflightPanel" h:PanelSpacing.Spacing="8"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Height="24"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 7 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="💾 Save Profile" Style="{StaticResource GhostButtonStyle}"
                            ToolTip="Save this configuration as a .gibprofile file you can reload later"
                            Click="SaveProfile_Click"/>
                    <Button x:Name="BuildButton" Content="Build ISO →" Style="{StaticResource LargePrimaryButtonStyle}"
                            Click="BuildISO_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
