<UserControl x:Class="GoldenISOBuilder.Views.Step4Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="ADMIN ACCOUNT" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Configure the local administrator account for the deployed image"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Form -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0" h:PanelSpacing.Spacing="20">

                    <!-- Account Credentials -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="16">
                            <TextBlock Text="Account Credentials" Style="{StaticResource CardTitleText}"/>

                            <!-- Username -->
                            <StackPanel>
                                <TextBlock Text="Username" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <TextBox x:Name="UsernameBox" Text="Administrator"
                                         Style="{StaticResource TextInputStyle}"
                                         TextChanged="Username_TextChanged"/>
                                <TextBlock Text="This account will have local admin privileges"
                                           Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Password -->
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Password" Style="{StaticResource FieldLabelText}"/>
                                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                            FontSize="11" Padding="6,2" Content="Generate Strong Password"
                                            Click="GeneratePassword_Click"/>
                                </Grid>
                                <Grid>
                                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordBoxStyle}"
                                                 PasswordChanged="PasswordBox_Changed"/>
                                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                            Margin="0,0,4,0" Padding="6,4" VerticalAlignment="Center"
                                            Click="TogglePasswordVisibility_Click">
                                        <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                              Data="{StaticResource EyeIcon}" Stroke="{DynamicResource FG2Brush}"/>
                                    </Button>
                                </Grid>

                                <!-- Password Strength Bar -->
                                <StackPanel Margin="0,8,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Password Strength" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        <TextBlock x:Name="StrengthLabel" Text="" HorizontalAlignment="Right"
                                                   FontSize="11" FontWeight="Medium"/>
                                    </Grid>
                                    <Grid Height="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="StrBar1" Grid.Column="0" Background="{DynamicResource BG3Brush}" CornerRadius="3" Margin="0,0,3,0"/>
                                        <Border x:Name="StrBar2" Grid.Column="1" Background="{DynamicResource BG3Brush}" CornerRadius="3" Margin="0,0,3,0"/>
                                        <Border x:Name="StrBar3" Grid.Column="2" Background="{DynamicResource BG3Brush}" CornerRadius="3" Margin="0,0,3,0"/>
                                        <Border x:Name="StrBar4" Grid.Column="3" Background="{DynamicResource BG3Brush}" CornerRadius="3"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- Confirm Password -->
                            <StackPanel>
                                <TextBlock Text="Confirm Password" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PasswordBoxStyle}"
                                             PasswordChanged="ConfirmPassword_Changed"/>
                                <TextBlock x:Name="PasswordMismatch" Text="Passwords don't match"
                                           Foreground="{DynamicResource ErrBrush}" FontSize="11"
                                           Margin="0,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Account Options -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="12">
                            <TextBlock Text="Account Options" Style="{StaticResource CardTitleText}"/>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Auto-Login on First Boot"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock Text="Skip login screen on initial deployment"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoLoginToggle" HorizontalAlignment="Right"
                                              IsChecked="False" Style="{StaticResource ToggleSwitchStyle}"/>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Password Never Expires"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock Text="Disable password expiration policy"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="PasswordNeverExpiresToggle" HorizontalAlignment="Right" IsChecked="True"
                                              Style="{StaticResource ToggleSwitchStyle}"/>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Disable Guest Account"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock Text="Recommended for security compliance"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="DisableGuestToggle" HorizontalAlignment="Right" IsChecked="True"
                                              Style="{StaticResource ToggleSwitchStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- unattend.xml Preview -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="unattend.xml Preview" Style="{StaticResource CardTitleText}"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        FontSize="12" Content="Copy to Clipboard" Click="CopyXml_Click"/>
                            </Grid>
                            <Border Background="{DynamicResource BG1Brush}" CornerRadius="6"
                                    BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                    Padding="14,12">
                                <TextBox x:Name="UnattendPreview" IsReadOnly="True" Background="Transparent"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                         Foreground="{DynamicResource FG1Brush}"
                                         TextWrapping="NoWrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MaxHeight="220"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Height="24"/>
                </StackPanel>

                <!-- Right: Windows Login Preview -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Height="320" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Login Preview" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>
                        <!-- Simulated login screen — layered: wallpaper | dark overlay | UI -->
                        <Grid>
                            <!-- Layer 1: wallpaper background (ImageBrush set in code-behind when wallpaper is selected) -->
                            <Border x:Name="LoginBg" CornerRadius="8" ClipToBounds="True">
                                <Border.Background>
                                    <SolidColorBrush Color="#FF070E1C"/>
                                </Border.Background>
                            </Border>
                            <!-- Layer 2: semi-transparent dark overlay so text stays readable over any wallpaper -->
                            <Border x:Name="LoginOverlay" CornerRadius="8" Background="#CC050C18" Visibility="Collapsed"/>
                            <!-- Layer 3: the actual login UI — content is identical, no changes -->
                            <Border CornerRadius="8" Padding="20,24">
                                <StackPanel HorizontalAlignment="Center" h:PanelSpacing.Spacing="12">
                                    <Ellipse Width="64" Height="64" Fill="{DynamicResource BG3Brush}"/>
                                    <TextBlock x:Name="PreviewUsername" Text="Administrator"
                                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <Border Background="#33FFFFFF" CornerRadius="4" Padding="12,8" Width="180">
                                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                            <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                                  Data="{StaticResource LockIcon}" Stroke="#AAFFFFFF"/>
                                            <TextBlock Text="Password" Foreground="#88FFFFFF" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource Gold1Brush}" CornerRadius="20"
                                            Width="32" Height="32" HorizontalAlignment="Center">
                                        <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                              Data="{StaticResource ChevronRightIcon}" Stroke="#FF171921"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Text="Preview based on current settings"
                                   Foreground="{DynamicResource FG2Brush}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 4 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Continue →" Style="{StaticResource PrimaryButtonStyle}"
                            Click="Continue_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>




