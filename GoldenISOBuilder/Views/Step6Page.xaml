<UserControl x:Class="GoldenISOBuilder.Views.Step6Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="40,24,40,12">
            <StackPanel>
                <TextBlock Text="BUILD PROGRESS" Style="{StaticResource GoldEyebrowText}"/>
                <TextBlock x:Name="PageHeaderSubtitle" Text="Ready to build"
                           Foreground="{DynamicResource FG0Brush}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" h:PanelSpacing.Spacing="4">
                <ToggleButton x:Name="PipelineViewBtn" Content="Pipeline" IsChecked="True"
                              Style="{StaticResource SegButtonStyle}" Click="PipelineView_Click"/>
                <ToggleButton x:Name="CinematicViewBtn" Content="Cinematic"
                              Style="{StaticResource SegButtonStyle}" Click="CinematicView_Click"/>
            </StackPanel>
        </Grid>

        <!-- Overall Progress Bar -->
        <Grid Grid.Row="1" Margin="40,0,40,12">
            <ProgressBar x:Name="OverallBar" Style="{StaticResource GoldProgressBar}" Value="0" Height="6"/>
            <TextBlock x:Name="OverallPct" Text="0%" HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-18,0,0" Foreground="{DynamicResource Gold1Brush}" FontSize="11"/>
        </Grid>

        <!-- Pipeline View -->
        <Grid x:Name="PipelineView" Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="*"   MinWidth="260"/>
                <ColumnDefinition Width="260" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Pipeline Steps -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0"
                    Padding="14,0">
                <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto">
                    <StackPanel h:PanelSpacing.Spacing="4">
                        <!-- pipeline rows are populated dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Centre: Current Operation (ScrollViewer prevents vertical clipping) -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0" Padding="20,0">
                <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel VerticalAlignment="Center" Margin="0,20,0,20" h:PanelSpacing.Spacing="20">

                        <!-- Animated CD disc — code starts/stops rotation in StartBuild / StopDiscSpin -->
                        <Canvas Width="80" Height="80" HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform x:Name="CenterDiscRotation"/>
                            </Canvas.RenderTransform>
                            <!-- Disc body -->
                            <Ellipse Width="80" Height="80">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.5,0.42" GradientOrigin="0.42,0.38">
                                        <GradientStop Color="#1E3055" Offset="0"/>
                                        <GradientStop Color="#0B1628" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- Outer edge ring -->
                            <Ellipse Width="78" Height="78" Canvas.Left="1" Canvas.Top="1"
                                     Stroke="{DynamicResource Gold1Brush}" StrokeThickness="1.5"
                                     Fill="Transparent"/>
                            <!-- Data track rings (give depth to the disc surface) -->
                            <Ellipse Width="62" Height="62" Canvas.Left="9" Canvas.Top="9"
                                     Stroke="#4D8EF850" StrokeThickness="2.5" Fill="Transparent"/>
                            <Ellipse Width="46" Height="46" Canvas.Left="17" Canvas.Top="17"
                                     Stroke="#4D8EF830" StrokeThickness="1.5" Fill="Transparent"/>
                            <!-- Label sector A — top-right wedge (rotation is visible because it's off-centre) -->
                            <Path Data="M40,40 L40,18 A22,22 0 0 1 59.1,29 Z">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4D8EF850" Offset="0"/>
                                        <GradientStop Color="#4D8EF815" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>
                            <!-- Label sector B — bottom-left (amber tint, opposite quadrant) -->
                            <Path Data="M40,40 L40,62 A22,22 0 0 1 20.9,51 Z"
                                  Fill="#F5A62325"/>
                            <!-- Hub (iridescent centre ring) -->
                            <Ellipse Width="18" Height="18" Canvas.Left="31" Canvas.Top="31">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#5A9EFF" Offset="0"/>
                                        <GradientStop Color="#1A3060" Offset="0.65"/>
                                        <GradientStop Color="#0B1628" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- Centre hole -->
                            <Ellipse Width="6" Height="6" Canvas.Left="37" Canvas.Top="37"
                                     Fill="#0B1628"/>
                        </Canvas>

                        <StackPanel HorizontalAlignment="Center" h:PanelSpacing.Spacing="6">
                            <TextBlock x:Name="CenterTitle" Text="No build in progress"
                                       Foreground="{DynamicResource FG0Brush}"
                                       FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                            <TextBlock x:Name="CenterSubtitle" Text="Complete the wizard steps and click Build ISO to start."
                                       Foreground="{DynamicResource FG2Brush}" FontSize="13"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <StackPanel h:PanelSpacing.Spacing="6">
                            <TextBlock Text="Step Progress" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                            <ProgressBar x:Name="StepBar" Style="{StaticResource GoldProgressBar}" Value="0" Height="8"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Elapsed" Foreground="{DynamicResource FG2Brush}" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ElapsedLabel" Text="0:00" Foreground="{DynamicResource FG0Brush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Step" Foreground="{DynamicResource FG2Brush}" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="StepCountLabel" Text="0 / 0" Foreground="{DynamicResource FG0Brush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Completion / failure panels (RenderTransform needed for AnimateIn slide) -->
                        <Border x:Name="CompletionPanel" Visibility="Collapsed"
                                Background="{DynamicResource OkPillBgBrush}"
                                BorderBrush="{DynamicResource OkPillLineBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="14,12" Margin="0,4,0,0">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <TextBlock Text="✓  Build complete"
                                           Foreground="{DynamicResource OkBrush}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FinalIsoPath"
                                           Foreground="{DynamicResource FG0Brush}"
                                           FontSize="11" TextWrapping="Wrap"/>
                                <!-- WrapPanel so buttons don't overflow on narrow windows -->
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Open ISO folder"
                                            Style="{StaticResource DefaultButtonStyle}"
                                            Margin="0,0,8,6" Click="OpenIsoLocation_Click"/>
                                    <Button Content="Open log"
                                            Style="{StaticResource DefaultButtonStyle}"
                                            Margin="0,0,0,6" Click="OpenLog_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="FailurePanel" Visibility="Collapsed"
                                Background="{DynamicResource ErrPillBgBrush}"
                                BorderBrush="{DynamicResource ErrPillLineBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="14,12" Margin="0,4,0,0">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <TextBlock Text="✗  Build failed"
                                           Foreground="{DynamicResource ErrBrush}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FailureDetail"
                                           Foreground="{DynamicResource FG0Brush}"
                                           FontSize="11" TextWrapping="Wrap"/>
                                <TextBlock x:Name="FailureLogPath"
                                           Foreground="{DynamicResource FG2Brush}"
                                           FontSize="10" TextWrapping="Wrap"/>
                                <Button Content="Open log"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Click="OpenLog_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: Live Log with Info / Warning / Error tabs -->
            <Border Grid.Column="2" Padding="14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: "LIVE LOG" label -->
                    <TextBlock Grid.Row="0" Text="LIVE LOG" Foreground="{DynamicResource FG2Brush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <!-- Row 1: Tab pills + Copy button -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="3">
                            <ToggleButton x:Name="LogTabAll"   Content="All"
                                          IsChecked="True" Tag="all"
                                          Click="LogTab_Click"
                                          Style="{StaticResource SegButtonStyle}"
                                          Padding="10,3" FontSize="11"/>
                            <ToggleButton x:Name="LogTabWarn"  Content="⚠ Warnings"
                                          IsChecked="False" Tag="warn"
                                          Click="LogTab_Click"
                                          Style="{StaticResource SegButtonStyle}"
                                          Padding="10,3" FontSize="11"/>
                            <ToggleButton x:Name="LogTabError" Content="✗ Errors"
                                          IsChecked="False" Tag="error"
                                          Click="LogTab_Click"
                                          Style="{StaticResource SegButtonStyle}"
                                          Padding="10,3" FontSize="11"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                FontSize="11" Padding="6,2" Content="Copy" Click="CopyLog_Click"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Row 2: Log text area — three overlapping TextBoxes, only one shown at a time -->
                    <Border Grid.Row="2" Background="{DynamicResource BG1Brush}" CornerRadius="6"
                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                            Padding="2">
                        <Grid>
                            <!-- ALL tab — always appended to; shown by default -->
                            <TextBox x:Name="LogBoxAll"
                                     Visibility="Visible"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="{DynamicResource FG1Brush}"
                                     Background="{DynamicResource BG1Brush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="10,8" CaretBrush="Transparent"
                                     Text="Waiting for build to start…"/>

                            <!-- WARNINGS tab — lines classified as warnings -->
                            <TextBox x:Name="LogBoxWarn"
                                     Visibility="Collapsed"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="{DynamicResource WarnBrush}"
                                     Background="{DynamicResource BG1Brush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="10,8" CaretBrush="Transparent"
                                     Text=""/>

                            <!-- ERRORS tab — lines classified as errors (also shown in Warnings) -->
                            <TextBox x:Name="LogBoxError"
                                     Visibility="Collapsed"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="{DynamicResource ErrBrush}"
                                     Background="{DynamicResource BG1Brush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="10,8" CaretBrush="Transparent"
                                     Text=""/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Cinematic View — full-screen status with rotating disc, big stats -->
        <Grid x:Name="CinematicView" Grid.Row="2" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" h:PanelSpacing.Spacing="28">
                <!-- Large Cinematic CD — same design scaled 2× -->
                <Canvas Width="160" Height="160" HorizontalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="DiscRotation"/>
                    </Canvas.RenderTransform>
                    <!-- Disc body -->
                    <Ellipse Width="160" Height="160">
                        <Ellipse.Fill>
                            <RadialGradientBrush Center="0.5,0.42" GradientOrigin="0.42,0.38">
                                <GradientStop Color="#1E3055" Offset="0"/>
                                <GradientStop Color="#0B1628" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Outer edge ring -->
                    <Ellipse Width="157" Height="157" Canvas.Left="1.5" Canvas.Top="1.5"
                             Stroke="{DynamicResource Gold1Brush}" StrokeThickness="2"
                             Fill="Transparent"/>
                    <!-- Data track rings -->
                    <Ellipse Width="124" Height="124" Canvas.Left="18" Canvas.Top="18"
                             Stroke="#4D8EF850" StrokeThickness="5" Fill="Transparent"/>
                    <Ellipse Width="92" Height="92" Canvas.Left="34" Canvas.Top="34"
                             Stroke="#4D8EF830" StrokeThickness="3" Fill="Transparent"/>
                    <!-- Label sector A — top-right (radius 44 from centre 80,80) -->
                    <Path Data="M80,80 L80,36 A44,44 0 0 1 118.1,58 Z">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4D8EF855" Offset="0"/>
                                <GradientStop Color="#4D8EF818" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                    </Path>
                    <!-- Label sector B — bottom-left (amber) -->
                    <Path Data="M80,80 L80,124 A44,44 0 0 1 41.9,102 Z"
                          Fill="#F5A62328"/>
                    <!-- Hub ring -->
                    <Ellipse Width="36" Height="36" Canvas.Left="62" Canvas.Top="62">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#5A9EFF" Offset="0"/>
                                <GradientStop Color="#1A3060" Offset="0.65"/>
                                <GradientStop Color="#0B1628" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Centre hole -->
                    <Ellipse Width="11" Height="11" Canvas.Left="74.5" Canvas.Top="74.5"
                             Fill="#0B1628"/>
                </Canvas>

                <StackPanel HorizontalAlignment="Center" h:PanelSpacing.Spacing="6">
                    <TextBlock x:Name="CineTitle" Text="No build in progress"
                               Foreground="{DynamicResource FG0Brush}"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CineSubtitle" Text="Complete the wizard steps and click Build ISO to start."
                               Foreground="{DynamicResource FG2Brush}" FontSize="15"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="640" TextAlignment="Center"/>
                </StackPanel>

                <ProgressBar x:Name="CineBar" Style="{StaticResource GoldProgressBar}"
                             Width="500" Height="8" Value="0"/>

                <Grid Width="500">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="Elapsed" Foreground="{DynamicResource FG2Brush}" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CineElapsed" Text="0:00"
                                   Foreground="{DynamicResource FG0Brush}" FontSize="22"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Step" Foreground="{DynamicResource FG2Brush}" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CineStepCount" Text="0 / 0"
                                   Foreground="{DynamicResource FG0Brush}" FontSize="22"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="Progress" Foreground="{DynamicResource FG2Brush}" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CinePct" Text="0%"
                                   Foreground="{DynamicResource Gold1Brush}" FontSize="22"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Footer Controls -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <!-- Left: nothing during build; shown when complete -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <!-- Cancel — visible while build is running, hidden otherwise -->
                    <Button x:Name="CancelBtn"
                            Content="⏹ Cancel"
                            Style="{StaticResource DefaultButtonStyle}"
                            Foreground="{DynamicResource ErrBrush}"
                            Visibility="Collapsed"
                            Click="CancelBuild_Click"/>
                    <!-- Wizard / New Build — visible when idle or after completion, hidden during build -->
                    <Button x:Name="NewBuildBtn"
                            Content="← Go to Wizard"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="18,0"
                            Click="NewBuild_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
