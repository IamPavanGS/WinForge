<UserControl x:Class="GoldenISOBuilder.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,16">
            <TextBlock Text="SETTINGS" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Configure application preferences and defaults"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Settings Layout: Sidebar + Content + Save Bar -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Settings Sidebar (spans content row + save-bar row) -->
            <Border Grid.Column="0" Grid.RowSpan="2"
                    BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0"
                    Padding="16,0">
                <StackPanel h:PanelSpacing.Spacing="4">
                    <Button x:Name="NavGeneral" Content="General" CommandParameter="general"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavPaths" Content="Paths &amp; Storage" CommandParameter="paths"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavBuild" Content="Build Defaults" CommandParameter="build"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavSecurity" Content="Security" CommandParameter="security"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavNotifications" Content="Notifications" CommandParameter="notifications"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavAdvanced" Content="Advanced" CommandParameter="advanced"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavAdk" Content="Windows ADK" CommandParameter="adk"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                    <Button x:Name="NavAbout" Content="About" CommandParameter="about"
                            Style="{StaticResource SettingsNavButtonStyle}"
                            Click="SettingsNav_Click"/>
                </StackPanel>
            </Border>

            <!-- Settings Content -->
            <ScrollViewer x:Name="SettingsScrollViewer" Focusable="False"
                          Grid.Row="0" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto" Margin="40,0,40,0"
                          ScrollChanged="SettingsScroll_Changed">
                <StackPanel h:PanelSpacing.Spacing="20" Margin="0,0,0,40">

                    <!-- General Section -->
                    <Border x:Name="GeneralCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="0">
                            <TextBlock Text="General" Style="{StaticResource CardTitleText}" Margin="0,0,0,20"/>

                            <!-- Theme -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Application Theme" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Choose the visual theme" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                    <Border x:Name="ThemeDarkOption" Cursor="Hand"
                                            Background="{DynamicResource BG3Brush}"
                                            BorderBrush="{DynamicResource Gold1Brush}" BorderThickness="1.5"
                                            CornerRadius="8" Padding="14,8"
                                            MouseLeftButtonDown="ThemeDark_Click">
                                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                            <Border Width="14" Height="14" CornerRadius="7"
                                                    Background="#171921" BorderBrush="#C9A84C" BorderThickness="1.5"/>
                                            <TextBlock Text="Dark (Gold)" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="ThemeLightOption" Cursor="Hand"
                                            Background="{DynamicResource BG3Brush}"
                                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="14,8"
                                            MouseLeftButtonDown="ThemeLight_Click">
                                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                            <Border Width="14" Height="14" CornerRadius="7"
                                                    Background="#F0F2F7" BorderBrush="#C9A84C" BorderThickness="1.5"/>
                                            <TextBlock Text="Light (Gold)" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Language -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Interface Language" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Display language for the UI"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <ComboBox x:Name="LanguageCombo" Grid.Column="1" MinWidth="160"
                                          IsEnabled="False" ToolTip="Multi-language support is planned for a future release"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Auto-save -->
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Auto-save Profiles" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Automatically save build profiles as you work"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoSaveProfilesToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Paths & Storage Section -->
                    <Border x:Name="PathsCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="0">
                            <TextBlock Text="Paths &amp; Storage" Style="{StaticResource CardTitleText}" Margin="0,0,0,20"/>

                            <!-- Default Output Path -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Default Output Path" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DefaultOutputBox" Grid.Column="0"
                                             Style="{StaticResource MonoTextInputStyle}"/>
                                    <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                            Style="{StaticResource DefaultButtonStyle}"
                                            Click="BrowseDefaultOutput_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- Default Workspace Path -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Default Workspace Path" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DefaultWorkspaceBox" Grid.Column="0"
                                             Style="{StaticResource MonoTextInputStyle}"/>
                                    <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                            Style="{StaticResource DefaultButtonStyle}"
                                            Click="BrowseDefaultWorkspace_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- Profile Storage -->
                            <StackPanel>
                                <TextBlock Text="Profile Storage" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ProfileStorageBox" Grid.Column="0"
                                             Style="{StaticResource MonoTextInputStyle}"/>
                                    <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                            Style="{StaticResource DefaultButtonStyle}"
                                            Click="BrowseProfileStorage_Click"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Build Defaults Section -->
                    <Border x:Name="BuildCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="0">
                            <TextBlock Text="Build Defaults" Style="{StaticResource CardTitleText}" Margin="0,0,0,20"/>

                            <!-- Compression Level -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="WIM Compression" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Compression level for the output WIM"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <ComboBox x:Name="CompressionCombo" Grid.Column="1" MinWidth="160"
                                          SelectionChanged="CompressionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Maximum (smaller, slower)" Tag="max" IsSelected="True"/>
                                    <ComboBoxItem Content="Fast (larger, quicker)"   Tag="fast"/>
                                    <ComboBoxItem Content="None"                      Tag="none"/>
                                </ComboBox>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Verify ISO -->
                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Verify ISO after build" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="SHA-256 checksum validation on completion"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="VerifyIsoToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Clean Workspace -->
                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Clean workspace after build" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Delete temporary files when build completes"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="CleanWorkspaceToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Clear Build History -->
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Build History" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Clear all records from the build history list"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <Button x:Name="ClearHistoryBtn" Content="Clear History"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Foreground="{DynamicResource ErrBrush}"
                                        Height="32" Padding="14,0"
                                        Click="ClearHistory_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Notifications Section -->
                    <Border x:Name="NotificationsCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="0">
                            <TextBlock Text="Notifications" Style="{StaticResource CardTitleText}" Margin="0,0,0,20"/>

                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Build Complete Notification" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Windows toast notification when build finishes"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="BuildCompleteToastToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Error Alerts" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Alert on build errors and warnings"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="ErrorAlertsToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Sound on Completion" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Play a sound when build is done"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="SoundOnCompleteToggle" HorizontalAlignment="Right" IsChecked="False"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" Margin="0,0,0,16"/>

                            <!-- Auto-fetch Updates &amp; Drivers (experimental) — gates the new
                                 Windows Update slipstream + OEM driver-pack auto-download
                                 features. Off by default so existing builds are unaffected. -->
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Auto-fetch Updates &amp; Drivers (experimental)"
                                               Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Enable the Windows Update slipstream panel and the Dell/HP/Lenovo driver-pack auto-download in Step 2. Off keeps the wizard exactly as it was."
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoFetchToggle" HorizontalAlignment="Right" IsChecked="False"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          Checked="AutoFetchToggle_Changed"
                                          Unchecked="AutoFetchToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Windows ADK Section -->
                    <Border x:Name="AdkCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="14">
                            <TextBlock Text="Windows ADK (Deployment Tools)" Style="{StaticResource CardTitleText}"/>
                            <TextBlock Text="Required for the final 'Build Bootable ISO' step (oscdimg.exe). Download is ~150 MB; full install ~250 MB on disk."
                                       Foreground="{DynamicResource FG2Brush}" FontSize="11.5" TextWrapping="Wrap"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Status" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="6">
                                        <TextBlock x:Name="AdkStatusDot" Text="●" FontSize="14"
                                                   Foreground="{DynamicResource WarnBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AdkStatusLabel" Text="Checking…"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button x:Name="AdkInstallBtn" Grid.Column="1" Content="Download &amp; Install"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        VerticalAlignment="Center"
                                        Click="InstallAdk_Click"/>
                            </Grid>

                            <!-- Progress (hidden until install starts) -->
                            <StackPanel x:Name="AdkInstallPanel" Visibility="Collapsed" h:PanelSpacing.Spacing="6">
                                <Grid>
                                    <TextBlock x:Name="AdkInstallStatus" Text=""
                                               Foreground="{DynamicResource FG1Brush}" FontSize="12"/>
                                    <TextBlock x:Name="AdkInstallPct" Text="" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource Gold1Brush}" FontSize="12"/>
                                </Grid>
                                <ProgressBar x:Name="AdkInstallBar" Style="{StaticResource GoldProgressBar}"
                                             Height="6" Value="0"/>
                                <Button x:Name="AdkCancelBtn" Content="Cancel"
                                        Style="{StaticResource GhostButtonStyle}"
                                        HorizontalAlignment="Right"
                                        Click="CancelAdkInstall_Click"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- About Section -->
                    <Border x:Name="AboutCard" Style="{StaticResource CardStyle}">
                        <StackPanel h:PanelSpacing.Spacing="16">
                            <TextBlock Text="About" Style="{StaticResource CardTitleText}"/>
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="16">
                                <Border Width="48" Height="48" CornerRadius="10"
                                        Background="{DynamicResource BG3Brush}">
                                    <Path Style="{StaticResource IconPath}" Width="28" Height="28"
                                          Data="{StaticResource DiscIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ALE Image Forge" Foreground="{DynamicResource FG0Brush}"
                                               FontSize="16" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Version " Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                        <TextBlock x:Name="AppVersionLabel" Text="?" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                        <TextBlock Text=" · Enterprise Edition" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="Created by Pavan G S" Foreground="{DynamicResource FG3Brush}"
                                               FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel h:PanelSpacing.Spacing="8">
                                <Grid>
                                    <TextBlock Text=".NET Runtime" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                    <TextBlock x:Name="DotNetVersionLabel" Text="?" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource FG1Brush}" FontSize="12"/>
                                </Grid>
                                <Border Style="{StaticResource DividerStyle}"/>
                                <Grid>
                                    <TextBlock Text="Windows ADK" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                    <TextBlock x:Name="AdkVersionLabel" Text="?" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource FG1Brush}" FontSize="12" FontFamily="Consolas"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Button Content="Check for Updates" Style="{StaticResource DefaultButtonStyle}" Click="CheckForUpdates_Click"/>
                                <Button Content="View Logs" Style="{StaticResource GhostButtonStyle}" Click="ViewLogs_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Save Bar ──────────────────────────────────────────────── -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="{DynamicResource BG1Brush}"
                    BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                    Padding="40,14">
                <!-- Three columns prevent the hint, status, and button from overlapping
                     when the window is narrow.  Hint truncates with ellipsis if needed. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Changes to paths take effect after saving."
                               Foreground="{DynamicResource FG2Brush}" FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="1"
                               x:Name="SaveStatusText" Text=""
                               Foreground="{DynamicResource OkBrush}" FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="320"
                               Margin="0,0,16,0"/>

                    <Button Grid.Column="2"
                            Content="Save Settings"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SaveSettings_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>



