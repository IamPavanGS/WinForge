<Window x:Class="GoldenISOBuilder.Views.GroupPolicyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        ShowInTaskbar="False" Width="940" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="Transparent" Opacity="0"
        FontFamily="Segoe UI">

    <!-- Entrance animation: fade + slide up -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.22">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Padding="12">
        <Border x:Name="DialogRoot"
                Background="{DynamicResource BG1Brush}"
                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="24,20,24,20"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SlideTransform"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="3" Color="#000000" Opacity="0.18"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header           -->
                    <RowDefinition Height="Auto"/>   <!-- Search bar       -->
                    <RowDefinition Height="*"/>      <!-- Tree + List      -->
                    <RowDefinition Height="Auto"/>   <!-- Detail panel     -->
                    <RowDefinition Height="Auto"/>   <!-- Footer buttons   -->
                </Grid.RowDefinitions>

                <!-- ══ Header ══════════════════════════════════════════════ -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Local Group Policy Editor"
                                   Foreground="{DynamicResource FG0Brush}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Browse ADMX policies and inject them into the offline registry during the build"
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Style="{StaticResource GhostButtonStyle}" FontSize="14" Padding="8,2"
                            Click="Cancel_Click" FocusVisualStyle="{x:Null}"/>
                </Grid>

                <!-- ══ Search bar ═══════════════════════════════════════════ -->
                <TextBox x:Name="SearchBox" Grid.Row="1"
                         Style="{StaticResource TextInputStyle}"
                         TextChanged="Search_Changed" IsEnabled="False">
                    <TextBox.Tag>Search across all policies…</TextBox.Tag>
                </TextBox>

                <!-- ══ Tree (left) + Policy list (right) ═══════════════════ -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="248"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Category tree ────────────────────────────────────── -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource BG0Brush}"
                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                            CornerRadius="6">
                        <TreeView x:Name="CategoryTree"
                                  Background="Transparent" BorderThickness="0"
                                  Padding="4"
                                  SelectedItemChanged="CategoryTree_SelectedItemChanged"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <Setter Property="Foreground" Value="{DynamicResource FG1Brush}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="2,4,2,4"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="IsExpanded" Value="False"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Border>

                    <!-- Policy list ──────────────────────────────────────── -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource BG0Brush}"
                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <!-- Loading / empty state overlay -->
                            <StackPanel x:Name="LoadingPanel"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar x:Name="LoadProgressBar" IsIndeterminate="True"
                                             Width="200" Height="4"
                                             Style="{StaticResource GoldProgressBar}"
                                             Margin="0,0,0,10"/>
                                <TextBlock x:Name="LoadingText" Text="Loading ADMX policy definitions…"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="13"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Empty / select-category hint -->
                            <TextBlock x:Name="SelectCategoryHint"
                                       Text="← Select a category to browse policies"
                                       Foreground="{DynamicResource FG3Brush}" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <!-- Actual policy rows -->
                            <ScrollViewer x:Name="PolicyListScroller"
                                          VerticalScrollBarVisibility="Auto" Focusable="False"
                                          Padding="6" Visibility="Collapsed">
                                <StackPanel x:Name="PolicyListPanel" Margin="2"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══ Detail / configure panel (hidden until policy clicked) ══ -->
                <Border Grid.Row="3" x:Name="DetailPanel" Visibility="Collapsed" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="CONFIGURE POLICY"
                                   Foreground="{DynamicResource Gold1Brush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Policy name + state selector pill row -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailPolicyName"
                                                   Foreground="{DynamicResource FG0Brush}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="DetailCategoryPath"
                                                   Foreground="{DynamicResource FG3Brush}"
                                                   FontSize="11" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- State pill selector (Border-based for custom styling) -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                Margin="16,0,0,0" VerticalAlignment="Center">
                                        <Border x:Name="PillNotConfigured" Tag="NotConfigured"
                                                CornerRadius="4" Padding="10,5"
                                                Cursor="Hand" Margin="0,0,4,0"
                                                MouseLeftButtonUp="StatePill_Click">
                                            <TextBlock x:Name="PillNotConfiguredText"
                                                       Text="Not Configured" FontSize="11"/>
                                        </Border>
                                        <Border x:Name="PillEnabled" Tag="Enabled"
                                                CornerRadius="4" Padding="10,5"
                                                Cursor="Hand" Margin="0,0,4,0"
                                                MouseLeftButtonUp="StatePill_Click">
                                            <TextBlock x:Name="PillEnabledText"
                                                       Text="Enabled" FontSize="11"/>
                                        </Border>
                                        <Border x:Name="PillDisabled" Tag="Disabled"
                                                CornerRadius="4" Padding="10,5"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="StatePill_Click">
                                            <TextBlock x:Name="PillDisabledText"
                                                       Text="Disabled" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Description (hidden if empty) -->
                                <Border x:Name="DescriptionPanel" Grid.Row="1"
                                        Background="{DynamicResource BG1Brush}" CornerRadius="5"
                                        Padding="10,8" Margin="0,0,0,10" Visibility="Collapsed">
                                    <ScrollViewer MaxHeight="68"
                                                  VerticalScrollBarVisibility="Auto" Focusable="False">
                                        <TextBlock x:Name="DetailDescription"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- Registry path hint -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <TextBlock Text="Registry: "
                                               Foreground="{DynamicResource FG3Brush}" FontSize="11"/>
                                    <TextBlock x:Name="DetailRegPath"
                                               Foreground="{DynamicResource FG3Brush}"
                                               FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" MaxWidth="540"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Optional element inputs (e.g. decimal, text, enum extra fields) -->
                        <Border x:Name="ElementsPanel" Visibility="Collapsed" Margin="0,8,0,0"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="POLICY OPTIONS"
                                           Foreground="{DynamicResource Gold1Brush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <StackPanel x:Name="ElementsContainer"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ Footer ════════════════════════════════════════════════ -->
                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Button Content="Cancel" HorizontalAlignment="Left"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="18,8" FontSize="13" FocusVisualStyle="{x:Null}"
                            Click="Cancel_Click"/>
                    <Button x:Name="AddPolicyBtn"
                            Content="Add Policy" HorizontalAlignment="Right"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,8" FontSize="13" FocusVisualStyle="{x:Null}"
                            IsEnabled="False" Click="Ok_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
