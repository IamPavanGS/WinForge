<UserControl x:Class="GoldenISOBuilder.Views.Step1Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="SOURCE &amp; OUTPUT" Style="{StaticResource GoldEyebrowText}" Foreground="{DynamicResource SourceAccentBrush}"/>
            <TextBlock Text="Configure your Windows ISO source and build output"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel h:PanelSpacing.Spacing="20">

                <!-- ══ ISO Source ══════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Windows ISO Source" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>

                        <!-- ISO picker panel — hidden once an ISO is loaded -->
                        <StackPanel x:Name="IsoPickerPanel" h:PanelSpacing.Spacing="12">

                            <!-- Drop zone (click to browse) -->
                            <Border x:Name="DropZone" Style="{StaticResource DropZoneStyle}"
                                    MouseLeftButtonDown="DropZone_Click" Cursor="Hand"
                                    AllowDrop="True"
                                    DragOver="DropZone_DragOver"
                                    Drop="DropZone_Drop">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="24,28,24,28" h:PanelSpacing.Spacing="8">
                                    <Path Style="{StaticResource IconPath}" Width="32" Height="32"
                                          Data="{StaticResource UploadIcon}"
                                          Stroke="{DynamicResource FG2Brush}"/>
                                    <TextBlock Text="Drop Windows ISO here  ·  or click to browse"
                                               Foreground="{DynamicResource FG1Brush}" FontSize="14"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tip: if the browser shows no files, paste the full path below instead"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Direct path paste row -->
                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path:" FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource FG2Brush}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="IsoPathBox" Grid.Column="1"
                                             Style="{StaticResource TextInputStyle}"
                                             FontFamily="Consolas" FontSize="12"
                                             PreviewKeyDown="IsoPathBox_KeyDown"
                                             ToolTip="Paste the full ISO path here (e.g. D:\ISOs\Win11.iso) and press Enter"/>
                                    <Button Grid.Column="2" Content="Load →" Margin="8,0,0,0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Padding="10,6" Click="LoadPathBox_Click"
                                            ToolTip="Load the ISO from the path above"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Scanning state (shown while DISM runs) -->
                        <Border x:Name="ScanningPanel" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="8"
                                BorderBrush="{DynamicResource Gold1Brush}" BorderThickness="1"
                                Padding="24,28">
                            <StackPanel HorizontalAlignment="Center" h:PanelSpacing.Spacing="10">
                                <TextBlock Text="Analyzing ISO…"
                                           Foreground="{DynamicResource FG0Brush}" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ScanningStatusText" Text="Mounting…"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Selected ISO info (shown after successful analysis) -->
                        <Border x:Name="SelectedISOPanel" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="8"
                                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                Padding="16,12" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Style="{StaticResource IconPath}" Width="20" Height="20"
                                      Data="{StaticResource FileIcon}" Stroke="{DynamicResource SourceAccentBrush}"
                                      Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="ISOFileName" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock x:Name="ISOFileSize" Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="Change" Style="{StaticResource GhostButtonStyle}"
                                        Click="ChangeISO_Click" FontSize="12"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ ISO Boot Language ════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="12">

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource GlobeIcon}" Stroke="{DynamicResource SourceAccentBrush}"/>
                            <TextBlock Text="ISO Boot Language" Style="{StaticResource CardTitleText}"/>
                        </StackPanel>
                        <TextBlock Text="Auto-detected from the ISO when loaded. Override only if detection is wrong. Must match the ISO's boot.wim language — a mismatch causes 0x8007000D at boot."
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"/>

                        <!-- Search box -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Style="{StaticResource IconPath}" Width="14" Height="14"
                                  Data="{StaticResource SearchIcon}" Stroke="{DynamicResource FG2Brush}"
                                  Margin="10,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="LangSearchBox" Grid.Column="1"
                                     Style="{StaticResource TextInputStyle}"
                                     FontSize="12"
                                     TextChanged="LangSearch_TextChanged"/>
                        </Grid>

                        <!-- Language list -->
                        <Border Background="{DynamicResource BG1Brush}" CornerRadius="6"
                                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                            <ListBox x:Name="LangListBox"
                                     MaxHeight="200"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionChanged="LangList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,7"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource FG0Brush}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BG3Brush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Gold1Brush}"/>
                                                <Setter Property="Foreground" Value="#FF171921"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Code}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource FG2Brush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Selected language banner -->
                        <Border x:Name="LangSelectedBanner" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                      Data="{StaticResource CheckCircleIcon}" Stroke="{DynamicResource OkBrush}"/>
                                <TextBlock x:Name="LangSelectedText"
                                           Foreground="{DynamicResource FG0Brush}" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ══ Target OS Language ═══════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="12">

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource GlobeIcon}" Stroke="{DynamicResource SourceAccentBrush}"/>
                            <TextBlock Text="Target OS Language" Style="{StaticResource CardTitleText}"/>
                        </StackPanel>
                        <TextBlock Text="The locale applied to the installed Windows (keyboard, UI, region). Independent of the ISO boot language — you can deploy en-US Windows from an en-GB ISO."
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap"/>

                        <ComboBox x:Name="TargetLocaleCombo"
                                  FontSize="13"
                                  Padding="10,7"
                                  SelectionChanged="TargetLocaleCombo_SelectionChanged"/>

                    </StackPanel>
                </Border>

                <!-- ══ Windows Edition ═════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Windows Edition" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>

                        <!-- Pre-scan placeholder (hidden once ISO is loaded) -->
                        <TextBlock x:Name="EditionNoIsoText"
                                   Text="Load a Windows ISO above — all editions found inside the image will appear here."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="13"/>

                        <!-- Dynamic edition list: one radio button per WIM index ──────── -->
                        <!-- Populated by ApplyEditionAvailability() after ISO analysis.   -->
                        <!-- Scrollable so ISOs with 10+ editions (e.g. multi-edition     -->
                        <!-- retail media) don't push the rest of the page down.           -->
                        <Border x:Name="EditionListBorder" Visibility="Collapsed"
                                Background="{DynamicResource BG1Brush}"
                                CornerRadius="6"
                                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                            <ScrollViewer Focusable="False"
                                          MaxHeight="280"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="2">
                                <StackPanel x:Name="EditionPanel" Margin="4"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Edition hint strip (shown / updated when a radio is selected) -->
                        <Border x:Name="EditionInfoBorder" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}"
                                CornerRadius="8" Padding="14,10" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                                <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                      Data="{StaticResource ShieldIcon}" Stroke="{DynamicResource InfoBrush}"/>
                                <TextBlock x:Name="EditionInfoText"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="13"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ Architecture ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Architecture" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="20">
                            <RadioButton x:Name="ArchX64"   Content="x64 (64-bit)" IsChecked="True"
                                         GroupName="Architecture"
                                         Style="{StaticResource CustomRadioStyle}"
                                         Checked="Arch_Checked"/>
                            <RadioButton x:Name="ArchX86"   Content="x86 (32-bit)"
                                         GroupName="Architecture"
                                         Style="{StaticResource CustomRadioStyle}"
                                         Checked="Arch_Checked"/>
                            <RadioButton x:Name="ArchARM64" Content="ARM64"
                                         GroupName="Architecture"
                                         Style="{StaticResource CustomRadioStyle}"
                                         Checked="Arch_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══ Output Configuration ════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Output Configuration" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>

                        <!-- Output Path -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Output Path" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputPathBox" Grid.Column="0"
                                         Text="D:\ISO_Build\Output"
                                         Style="{StaticResource MonoTextInputStyle}"
                                         TextChanged="OutputPath_TextChanged"/>
                                <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Click="BrowseOutput_Click"/>
                            </Grid>
                            <TextBlock Text="ISO and build artifacts will be saved here"
                                       Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Workspace Path -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Workspace Path (Temp)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WorkspacePathBox" Grid.Column="0"
                                         Text="D:\ISO_Build\Workspace"
                                         Style="{StaticResource MonoTextInputStyle}"/>
                                <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Click="BrowseWorkspace_Click"/>
                            </Grid>
                            <TextBlock Text="Temporary files during build (requires ~15 GB free)"
                                       Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Output Filename -->
                        <StackPanel>
                            <TextBlock Text="Output Filename" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                            <TextBox x:Name="OutputFilenameBox"
                                     Text="GoldenImage_{edition}_{date}.iso"
                                     Style="{StaticResource MonoTextInputStyle}"/>
                            <TextBlock Text="Use {edition}, {date}, {version} as dynamic tokens"
                                       Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══ Disk Space ══════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Disk Space" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>
                        <!-- Populated dynamically in code-behind -->
                        <StackPanel x:Name="DriveSpacePanel" h:PanelSpacing.Spacing="10"/>
                    </StackPanel>
                </Border>

                <Border Height="24"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 1 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Continue →" Style="{StaticResource PrimaryButtonStyle}"
                            Click="Continue_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
