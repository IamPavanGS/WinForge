<UserControl x:Class="GoldenISOBuilder.Views.StepAdvancedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="ADVANCED OPTIONS" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Fine-tune deployment identity, Windows features, OEM branding, and power settings"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel h:PanelSpacing.Spacing="20">

                <!-- ══ Deployment Identity ════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="16">
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource BriefcaseIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                            <TextBlock Text="Deployment Identity" Style="{StaticResource CardTitleText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Organisation Name" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <TextBox x:Name="OrgNameBox" Style="{StaticResource TextInputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Registered Owner" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <TextBox x:Name="OwnerBox" Style="{StaticResource TextInputStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Product Key (KMS / MAK)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                <TextBox x:Name="ProductKeyBox" Style="{StaticResource MonoTextInputStyle}"
                                         MaxLength="29"/>
                                <TextBlock Text="Leave blank to use the key embedded in the ISO"
                                           Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- ── Computer Naming ─────────────────────────────── -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,12">
                            <StackPanel h:PanelSpacing.Spacing="10">
                                <!-- Toggle row -->
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Auto-Rename Computer at First Boot"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="Each deployed machine gets a unique name based on the prefix you set"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="EnableRenameToggle" HorizontalAlignment="Right"
                                              IsChecked="False" Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="EnableRename_Changed" Unchecked="EnableRename_Changed"/>
                                </Grid>

                                <!-- Prefix input — only shown when toggle is ON -->
                                <StackPanel x:Name="PrefixPanel" Visibility="Collapsed">
                                    <TextBlock Text="Prefix" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PrefixBox" Grid.Column="0"
                                                 Style="{StaticResource MonoTextInputStyle}"
                                                 MaxLength="10" CharacterCasing="Upper"
                                                 TextChanged="PrefixBox_TextChanged"/>
                                        <TextBlock x:Name="PrefixPreview" Grid.Column="1"
                                                   Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Text="→ e.g. CORP-12345"/>
                                    </Grid>
                                    <TextBlock Foreground="{DynamicResource FG3Brush}" FontSize="11" Margin="0,4,0,0"
                                               Text="Max 10 characters · A–Z, 0–9 only · the machine's BIOS serial is appended at first boot (total ≤ 15 chars)"/>

                                    <!-- Hostname template — default keeps today's behaviour byte-for-byte.
                                         Other options route through a separate first-boot resolver. -->
                                    <TextBlock Text="Suffix source" Style="{StaticResource FieldLabelText}" Margin="0,14,0,6"/>
                                    <ComboBox x:Name="HostnameTemplateCombo" Width="360" HorizontalAlignment="Left"
                                              SelectionChanged="HostnameTemplate_Changed">
                                        <ComboBoxItem Content="BIOS serial (default)" Tag="{}{PREFIX}{SERIAL}"/>
                                        <ComboBoxItem Content="Last 6 chars of BIOS serial" Tag="{}{PREFIX}{LAST6_SERIAL}"/>
                                        <ComboBoxItem Content="Last 6 hex of MAC address" Tag="{}{PREFIX}{LAST6_MAC}"/>
                                        <ComboBoxItem Content="SMBIOS asset tag (falls back to serial)" Tag="{}{PREFIX}{ASSETTAG}"/>
                                    </ComboBox>
                                    <TextBlock Foreground="{DynamicResource FG3Brush}" FontSize="11" Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Text="Default = today's behaviour (PREFIX + full BIOS serial). Other options use a different resolver at first boot, useful when BIOS serials collide or you track machines by MAC / asset tag."/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ OOBE Settings ══════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="12">
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource ZapIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                            <TextBlock Text="OOBE &amp; First-Boot Behaviour" Style="{StaticResource CardTitleText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Time zone -->
                        <StackPanel>
                            <TextBlock Text="Time Zone" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="TimeZoneBox" Style="{StaticResource ComboBoxStyle}"
                                      HorizontalAlignment="Stretch" MaxDropDownHeight="240"/>
                            <TextBlock Text="Applied to the deployed OS via Autounattend.xml (specialize + oobeSystem)"
                                       Style="{StaticResource FieldHintText}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                            <Grid>
                                <StackPanel Margin="0,0,72,0">
                                    <TextBlock Text="Skip Express Settings (OOBE)" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0">
                                        <Run Text="ON: zero-touch install — machine goes straight to desktop."/>
                                        <LineBreak/>
                                        <Run Text="OFF: operator clicks through Windows setup screens manually. BitLocker, hostname rename, certs and OneDrive removal still apply via SetupComplete.cmd. Only AutoLogon and the disk-clean fix are lost."/>
                                    </TextBlock>
                                </StackPanel>
                                <CheckBox x:Name="SkipOobeToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Hide EULA Page" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                    <TextBlock Text="Suppress the licence agreement screen during setup"
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                </StackPanel>
                                <CheckBox x:Name="HideEulaToggle" HorizontalAlignment="Right" IsChecked="True"
                                          Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>
                        </Border>
                        <!-- Auto-Login is configured in Step 4 (Admin Account) — no duplicate here -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="14,10">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                                <TextBlock Text="ℹ" Foreground="{DynamicResource InfoBrush}" FontSize="13"
                                           VerticalAlignment="Center"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                           Foreground="{DynamicResource FG2Brush}">
                                    <Run Text="Auto-Login is configured in "/>
                                    <Run Text="Step 4 → Admin Account" FontWeight="SemiBold"
                                         Foreground="{DynamicResource FG1Brush}"/>
                                    <Run Text=" — set it there to keep it alongside the admin password."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ Windows Optional Features ══════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10" Margin="0,0,0,14">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource LayersIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                            <TextBlock Text="Windows Optional Features" Style="{StaticResource CardTitleText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="These are injected offline via DISM /Enable-Feature before sealing the image"
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" h:PanelSpacing.Spacing="8">
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text=".NET Framework 3.5" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Required by legacy enterprise apps" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatDotNet35" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Hyper-V" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Hardware virtualisation platform" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatHyperV" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="WSL 2 (Windows Subsystem for Linux)" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Run Linux distros natively" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatWsl" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="OpenSSH Server" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Enables SSH remote management" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatSshServer" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" h:PanelSpacing.Spacing="8">
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Internet Information Services (IIS)" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Built-in web server" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatIis" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Telnet Client" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Legacy network diagnostics" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatTelnet" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="NFS Client" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Mount Unix/Linux network shares" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatNfs" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="RSAT Tools" Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                            <TextBlock Text="Remote Server Administration Tools" Foreground="{DynamicResource FG2Brush}" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="FeatRsat" HorizontalAlignment="Right" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══ Power Plan ═════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="12">
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource ZapIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                            <TextBlock Text="Default Power Plan" Style="{StaticResource CardTitleText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Balanced -->
                            <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="8" Padding="16,14"
                                    BorderThickness="1" Cursor="Hand"
                                    BorderBrush="{DynamicResource Gold1Brush}"
                                    Background="{DynamicResource NewBuildTileBrush}"
                                    MouseLeftButtonDown="PowerPlan_Click" Tag="Balanced">
                                <StackPanel>
                                    <RadioButton x:Name="PlanBalanced" GroupName="PowerPlan"
                                                 IsChecked="True" Style="{StaticResource CustomRadioStyle}"
                                                 Margin="0,0,0,6"/>
                                    <TextBlock Text="Balanced" Foreground="{DynamicResource FG0Brush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Automatic performance/power balance. Default for most workstations."
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- High Performance -->
                            <Border Grid.Column="1" Margin="0,0,8,0" CornerRadius="8" Padding="16,14"
                                    BorderThickness="1" Cursor="Hand"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    Background="{DynamicResource BG3Brush}"
                                    MouseLeftButtonDown="PowerPlan_Click" Tag="HighPerformance">
                                <StackPanel>
                                    <RadioButton x:Name="PlanHighPerf" GroupName="PowerPlan"
                                                 IsChecked="False" Style="{StaticResource CustomRadioStyle}"
                                                 Margin="0,0,0,6"/>
                                    <TextBlock Text="High Performance" Foreground="{DynamicResource FG0Brush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Maximum CPU clock, no sleep/hibernate. Best for workstations and VMs."
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Ultimate Performance -->
                            <Border Grid.Column="2" CornerRadius="8" Padding="16,14"
                                    BorderThickness="1" Cursor="Hand"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    Background="{DynamicResource BG3Brush}"
                                    MouseLeftButtonDown="PowerPlan_Click" Tag="UltimatePerformance">
                                <StackPanel>
                                    <RadioButton x:Name="PlanUltimate" GroupName="PowerPlan"
                                                 IsChecked="False" Style="{StaticResource CustomRadioStyle}"
                                                 Margin="0,0,0,6"/>
                                    <TextBlock Text="Ultimate Performance" Foreground="{DynamicResource FG0Brush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Eliminates micro-latencies. Ideal for servers and power-users."
                                               Foreground="{DynamicResource FG2Brush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══ OEM Branding ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="16">
                        <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                  Data="{StaticResource UserIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                            <TextBlock Text="OEM Branding" Style="{StaticResource CardTitleText}"
                                       VerticalAlignment="Center"/>
                            <Border Style="{StaticResource PillStyle}" Margin="4,0,0,0">
                                <TextBlock Text="System Properties"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Customises the Support Information shown in Settings → About and System Properties"
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0" h:PanelSpacing.Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="Manufacturer" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="OemMfgBox" Style="{StaticResource TextInputStyle}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Model" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="OemModelBox" Style="{StaticResource TextInputStyle}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" h:PanelSpacing.Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="Support URL" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="OemUrlBox" Style="{StaticResource TextInputStyle}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Support Phone" Style="{StaticResource FieldLabelText}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="OemPhoneBox" Style="{StaticResource TextInputStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Info note -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,10">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="8">
                                <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                                      Data="{StaticResource ShieldIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center">
                                    <Run Text="Values are written to "/>
                                    <Run FontFamily="Consolas" Foreground="{DynamicResource FG1Brush}"
                                         Text="HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OEMInformation"/>
                                    <Run Text=" in the offline image registry."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ Scheduled Tasks ═══════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel h:PanelSpacing.Spacing="12">

                        <!-- Header -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                                <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                      Data="{StaticResource ZapIcon}" Stroke="{DynamicResource Gold1Brush}"/>
                                <TextBlock Text="Scheduled Tasks" Style="{StaticResource CardTitleText}"
                                           VerticalAlignment="Center"/>
                                <Border Style="{StaticResource PillStyle}" Margin="4,0,0,0">
                                    <TextBlock Text="Task Scheduler"/>
                                </Border>
                            </StackPanel>
                            <Button x:Name="AddTaskBtn" Content="+ Add Task"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Right" Padding="14,6" FontSize="12"
                                    FocusVisualStyle="{x:Null}" Click="AddTask_Click"/>
                        </Grid>

                        <TextBlock Text="These tasks are created on the deployed OS via schtasks.exe inside SetupComplete.cmd"
                                   Foreground="{DynamicResource FG2Brush}" FontSize="12"/>

                        <!-- Task list -->
                        <StackPanel x:Name="TaskListPanel"/>

                        <!-- Empty-state hint -->
                        <Border x:Name="TaskEmptyHint"
                                Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="16,12">
                            <TextBlock Text="No scheduled tasks configured. Click '+ Add Task' to add one."
                                       Foreground="{DynamicResource FG3Brush}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Border>

                    </StackPanel>
                </Border>

                <Border Height="24"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 6 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Continue →" Style="{StaticResource PrimaryButtonStyle}"
                            Click="Continue_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
