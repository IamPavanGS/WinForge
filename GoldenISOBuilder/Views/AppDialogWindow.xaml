<Window x:Class="GoldenISOBuilder.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="420" MaxWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="Transparent" Opacity="0"
        FontFamily="Segoe UI">

    <!-- Entrance animation: fade + slide up from 14px below -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.22">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Outer transparent padding so the drop shadow has room to render -->
    <Border Padding="16">
        <Border x:Name="DialogRoot"
                Background="{DynamicResource BG1Brush}"
                BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="28,24,28,20"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SlideTransform"/>
            </Border.RenderTransform>
            <Border.Effect>
                <!-- Soft shadow — light enough to be invisible on white, visible on dark -->
                <DropShadowEffect BlurRadius="24" ShadowDepth="3"
                                  Color="#000000" Opacity="0.18"/>
            </Border.Effect>

            <StackPanel>

                <!-- Icon + texts -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">

                    <!-- Circular icon badge -->
                    <Border x:Name="IconBadge"
                            Width="40" Height="40" CornerRadius="20"
                            Margin="0,2,16,0" VerticalAlignment="Top">
                        <TextBlock x:Name="IconGlyph"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title + message -->
                    <!-- MinWidth ensures short messages still get a reasonable text column;
                         MaxWidth caps line length for long messages so the dialog stays
                         readable instead of stretching to full screen width. -->
                    <StackPanel VerticalAlignment="Center"
                                MinWidth="320" MaxWidth="540">
                        <TextBlock x:Name="TitleBlock"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FG0Brush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>
                        <TextBlock x:Name="MessageBlock"
                                   FontSize="13"
                                   Foreground="{DynamicResource FG1Brush}"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </StackPanel>
                </StackPanel>

                <!-- Thin divider -->
                <Border Height="1" Background="{DynamicResource LineBrush}" Margin="0,0,0,16"/>

                <!-- Buttons (added at runtime) -->
                <StackPanel x:Name="ButtonRow"
                            Orientation="Horizontal" HorizontalAlignment="Right"/>

            </StackPanel>
        </Border>
    </Border>
</Window>
