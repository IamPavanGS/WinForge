<UserControl x:Class="GoldenISOBuilder.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}">
    <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,28,36,40" MaxWidth="1280" HorizontalAlignment="Left">

            <!-- Hero grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Hero card -->
                <Border Grid.Column="0" CornerRadius="16" Margin="0,0,16,0" Padding="36,36,36,28"
                        ClipToBounds="True"
                        Background="{DynamicResource HeroCardBrush}"
                        BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="ALE IMAGE FORGE · ENTERPRISE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Gold1Brush}"/>
                        <TextBlock Margin="0,14,0,10" TextWrapping="Wrap" LineHeight="42">
                            <Run Text="Build a " FontSize="32" FontWeight="Bold"
                                 Foreground="{DynamicResource FG0Brush}"/>
                            <Run Text="Golden Image" FontSize="32" FontWeight="Bold"
                                 Foreground="{DynamicResource Gold1Brush}"/>
                            <Run Text=" of Windows 11" FontSize="32" FontWeight="Bold"
                                 Foreground="{DynamicResource FG0Brush}"/>
                            <LineBreak/>
                            <Run Text="that's deployment-ready." FontSize="32" FontWeight="Bold"
                                 Foreground="{DynamicResource FG0Brush}"/>
                        </TextBlock>
                        <TextBlock Text="Slipstream updates, inject drivers and language packs, harden privacy, and stage first-boot scripts — all from a single guided wizard. Outputs a bootable ISO with a verified hash."
                                   FontSize="14" Foreground="{DynamicResource FG1Brush}"
                                   TextWrapping="Wrap" MaxWidth="500" Margin="0,0,0,24" LineHeight="22"/>

                        <!-- WrapPanel so buttons reflow on narrow windows instead of clipping -->
                        <WrapPanel Orientation="Horizontal">
                            <Button Style="{StaticResource LargePrimaryButtonStyle}"
                                    Margin="0,0,10,8"
                                    Click="NewBuildBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource PlusIcon}"
                                          Stroke="{DynamicResource BG0Brush}" StrokeThickness="2" Width="15" Height="15"/>
                                    <TextBlock Text=" New Build" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource BG0Brush}"/>
                                    <Border Margin="8,0,0,0" Padding="4,2" CornerRadius="3"
                                            Background="{DynamicResource BG2Brush}"
                                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                                        <TextBlock Text="Ctrl+N" FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource LargeButtonStyle}"
                                    Margin="0,0,10,8"
                                    Click="QuickBuildBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource ZapIcon}"
                                          Stroke="{DynamicResource FG0Brush}" StrokeThickness="1.75"
                                          Width="14" Height="14"/>
                                    <TextBlock Text=" Quick Build" FontSize="13.5"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource LargeButtonStyle}"
                                    Margin="0,0,0,8"
                                    Click="OpenProfileBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource FolderOpenIcon}"
                                          Stroke="{DynamicResource FG0Brush}" StrokeThickness="1.75"
                                          Width="14" Height="14"/>
                                    <TextBlock Text=" Open Profile" FontSize="13.5"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Stats — populated from BuildHistoryStore on load -->
                        <StackPanel Orientation="Horizontal" Margin="0,28,0,0">
                            <StackPanel Margin="0,0,28,0">
                                <TextBlock x:Name="StatBuildsCount"
                                           Text="—" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="builds completed" FontSize="12" Foreground="{DynamicResource FG2Brush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,28,0">
                                <TextBlock x:Name="StatAvgDuration"
                                           Text="—" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="avg. duration" FontSize="12" Foreground="{DynamicResource FG2Brush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="StatSuccessRate"
                                           Text="—" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="success rate" FontSize="12" Foreground="{DynamicResource FG2Brush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action tiles -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <!-- Start new build tile (primary) -->
                    <Border CornerRadius="10" Padding="16" Margin="0,0,0,8" Cursor="Hand"
                            BorderThickness="1" MouseLeftButtonDown="NewBuildTile_Click"
                            Background="{DynamicResource NewBuildTileBrush}"
                            BorderBrush="{DynamicResource Gold3Brush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{DynamicResource Gold2Color}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource Gold3Color}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource PlusIcon}"
                                      Stroke="{DynamicResource BG0Brush}" StrokeThickness="2" Width="18" Height="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Start a new build" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="Walk through the 6-step wizard" FontSize="11.5"
                                           Foreground="{DynamicResource FG2Brush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Style="{StaticResource IconPath}"
                                  Data="{StaticResource ChevronRightIcon}"
                                  Stroke="{DynamicResource FG2Brush}" StrokeThickness="1.75"
                                  Width="16" Height="16" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Quick build tile -->
                    <Border CornerRadius="10" Padding="16" Margin="0,0,0,8" Cursor="Hand"
                            Background="{DynamicResource BG2Brush}"
                            BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1"
                            MouseLeftButtonDown="QuickBuildTile_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource BG3Brush}">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource ZapIcon}"
                                      Stroke="{DynamicResource Gold1Brush}" StrokeThickness="1.75"
                                      Width="16" Height="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Quick build" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="Re-run last saved profile" FontSize="11.5"
                                           Foreground="{DynamicResource FG2Brush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Style="{StaticResource IconPath}"
                                  Data="{StaticResource ChevronRightIcon}"
                                  Stroke="{DynamicResource FG2Brush}" StrokeThickness="1.75"
                                  Width="16" Height="16" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Open profile tile -->
                    <Border CornerRadius="10" Padding="16" Margin="0,0,0,8" Cursor="Hand"
                            Background="{DynamicResource BG2Brush}"
                            BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1"
                            MouseLeftButtonDown="OpenProfileTile_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource BG3Brush}">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource FolderOpenIcon}"
                                      Stroke="{DynamicResource Gold1Brush}" StrokeThickness="1.75"
                                      Width="16" Height="16"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Open profile" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FG0Brush}"/>
                                <TextBlock Text="Load a .gibprofile JSON" FontSize="11.5"
                                           Foreground="{DynamicResource FG2Brush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Style="{StaticResource IconPath}"
                                  Data="{StaticResource ChevronRightIcon}"
                                  Stroke="{DynamicResource FG2Brush}" StrokeThickness="1.75"
                                  Width="16" Height="16" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Drop hint -->
                    <Border CornerRadius="10" Padding="10,14" Margin="0,4,0,0"
                            BorderThickness="1.5">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{DynamicResource LineColor}" Opacity="0.7"/>
                        </Border.BorderBrush>
                        <TextBlock HorizontalAlignment="Center" FontSize="11.5"
                                   Foreground="{DynamicResource FG2Brush}">
                            <Run Text="⬆  Or drop a "/>
                            <Run Text=".gibprofile" FontFamily="Consolas" Foreground="{DynamicResource FG1Brush}"/>
                            <Run Text=" anywhere on this page"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Recent Builds -->
            <Grid Margin="0,36,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="RECENT BUILDS" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource FG2Brush}" VerticalAlignment="Center"/>
                <Button x:Name="ViewAllBtn" Grid.Column="1" Style="{StaticResource GhostButtonStyle}"
                        Height="26" FontSize="12" Click="ViewAllHistory_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ViewAllBtnText" Text="View all"/>
                        <Path x:Name="ViewAllChevron" Style="{StaticResource IconPath}" Data="{StaticResource ChevronRightIcon}"
                              Stroke="{DynamicResource FG0Brush}" Width="11" Height="11" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Recent builds list (populated from BuildHistoryStore on load) -->
            <Border x:Name="RecentBuildsEmpty" Background="{DynamicResource BG2Brush}"
                    CornerRadius="10" BorderBrush="{DynamicResource LineSoftBrush}"
                    BorderThickness="1" Padding="24,32" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Style="{StaticResource IconPath}" Width="32" Height="32"
                          Data="{StaticResource HistoryIcon}" Stroke="{DynamicResource FG3Brush}"
                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No builds yet" Foreground="{DynamicResource FG2Brush}"
                               FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
                    <TextBlock Text="Start a new build to see your history here"
                               Foreground="{DynamicResource FG3Brush}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Populated dynamically — one row per BuildRecord -->
            <Border x:Name="RecentBuildsPanel" Background="{DynamicResource BG2Brush}"
                    CornerRadius="10" BorderBrush="{DynamicResource LineSoftBrush}"
                    BorderThickness="1" Padding="4" Visibility="Collapsed">
                <StackPanel x:Name="RecentBuildsList"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>



