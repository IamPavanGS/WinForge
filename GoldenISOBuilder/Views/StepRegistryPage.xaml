<UserControl x:Class="GoldenISOBuilder.Views.StepRegistryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GoldenISOBuilder.Helpers"
             Background="{DynamicResource BG0Brush}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="REGISTRY CHANGES" Style="{StaticResource GoldEyebrowText}"/>
            <TextBlock Text="Configure registry settings applied to the offline Windows image before sealing"
                       Foreground="{DynamicResource FG2Brush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Focusable="False" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel h:PanelSpacing.Spacing="20">

                <!-- How it works info banner -->
                <Border Background="{DynamicResource BG3Brush}" CornerRadius="8"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="16,12">
                    <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="12">
                        <Path Style="{StaticResource IconPath}" Width="18" Height="18"
                              Data="{StaticResource ShieldIcon}" Stroke="{DynamicResource InfoBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel>
                            <TextBlock Text="How Registry Changes Are Applied"
                                       Foreground="{DynamicResource FG0Brush}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12" TextWrapping="Wrap">
                                <Run Text="Changes are injected into the offline WIM using DISM + "/>
                                <Run FontFamily="Consolas" Foreground="{DynamicResource FG1Brush}" Text="reg load"/>
                                <Run Text=". "/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource FG1Brush}" Text="HKLM"/>
                                <Run Text=" changes target the system hive (all users). "/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource FG1Brush}" Text="HKCU"/>
                                <Run Text=" changes target the Default User profile — applied to every new account created at first logon."/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Already-managed settings hint -->
                <Border Background="{DynamicResource OkPillBgBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource OkPillLineBrush}" BorderThickness="1" Padding="14,10">
                    <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                        <TextBlock Text="✓" Foreground="{DynamicResource OkBrush}"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource FG2Brush}">
                            <Run FontWeight="SemiBold" Foreground="{DynamicResource OkBrush}"
                                 Text="Dark Mode, Show File Extensions, and SMBv1 disable"/>
                            <Run Text=" are already applied automatically by the settings you chose in "/>
                            <Run FontWeight="SemiBold" Foreground="{DynamicResource FG1Brush}"
                                 Text="Step 3 (Customizations)"/>
                            <Run Text=". Adding them here again is harmless but unnecessary."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Predefined Tweaks -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Predefined Tweaks" Style="{StaticResource CardTitleText}"/>
                            <TextBlock Text="Common enterprise registry hardening" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource FG2Brush}" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- ── Privacy & Telemetry ── -->
                        <TextBlock Text="PRIVACY &amp; TELEMETRY" Foreground="{DynamicResource FG2Brush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel h:PanelSpacing.Spacing="4">

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Windows Telemetry"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Policies\Microsoft\Windows\DataCollection  →  AllowTelemetry = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Activity History"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Policies\Microsoft\Windows\System  →  EnableActivityFeed = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Advertising ID"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Policies\Microsoft\Windows\AdvertisingInfo  →  DisabledByGroupPolicy = 1 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ── Performance ── -->
                        <TextBlock Text="PERFORMANCE" Foreground="{DynamicResource FG2Brush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <StackPanel h:PanelSpacing.Spacing="4">

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable SysMain (Superfetch)"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Services\SysMain  →  Start = 4 (REG_DWORD)  —  Recommended for SSD deployments"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Windows Search Indexing Service"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Services\WSearch  →  Start = 4 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Hibernation"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Power  →  HiberbootEnabled = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ── Enterprise / Security ── -->
                        <TextBlock Text="ENTERPRISE / SECURITY" Foreground="{DynamicResource FG2Brush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <StackPanel h:PanelSpacing.Spacing="4">

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Require SMB Packet Signing (Client)"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters  →  RequireSecuritySignature = 1 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable NTLMv1 — Enforce NTLMv2 Only"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Control\Lsa  →  LmCompatibilityLevel = 5 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable AutoRun / AutoPlay on All Drives"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer  →  NoDriveTypeAutoRun = 0xFF (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Remote Registry Service"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SYSTEM\CurrentControlSet\Services\RemoteRegistry  →  Start = 4 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ── UI / Experience ── -->
                        <TextBlock Text="UI / EXPERIENCE" Foreground="{DynamicResource FG2Brush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <StackPanel h:PanelSpacing.Spacing="4">

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Enable Dark Theme by Default (All New Users)"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKCU (Default)\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize  →  AppsUseLightTheme = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKCU" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource Gold1Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Show File Extensions in Explorer"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKCU (Default)\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced  →  HideFileExt = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKCU" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource Gold1Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Cortana"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Policies\Microsoft\Windows\Windows Search  →  AllowCortana = 0 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Margin="0,0,12,0"
                                              Style="{StaticResource CustomCheckBoxStyle}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disable Tips &amp; Suggestions Notifications"
                                                   Foreground="{DynamicResource FG0Brush}" FontSize="13"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG3Brush}" TextWrapping="Wrap"
                                                   Text="HKLM\SOFTWARE\Policies\Microsoft\Windows\CloudContent  →  DisableSoftLanding = 1 (REG_DWORD)"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource BG1Brush}" CornerRadius="3"
                                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="HKLM" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource FG2Brush}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Custom Registry Entries -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Custom Registry Entries" Style="{StaticResource CardTitleText}"/>
                            <Button HorizontalAlignment="Right" Content="+ Add Entry"
                                    Style="{StaticResource GhostButtonStyle}" FontSize="12"
                                    Click="AddEntry_Click"/>
                        </Grid>

                        <!-- Column Headers -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="64"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Hive"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Key Path"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Value Name"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Type"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="Data"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="5" Text="Op"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <!-- Inline Add / Edit Form -->
                        <Border x:Name="EntryForm" Visibility="Collapsed"
                                Background="{DynamicResource BG3Brush}" CornerRadius="8"
                                BorderBrush="{DynamicResource Gold1Brush}" BorderThickness="1"
                                Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="FormTitle" Text="Add Registry Entry"
                                           Foreground="{DynamicResource FG0Brush}" FontSize="13"
                                           FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Hive | Key Path | Value Name | Type -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Hive" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FormHive" Style="{StaticResource ComboBoxStyle}">
                                            <ComboBoxItem Content="HKLM" IsSelected="True"/>
                                            <ComboBoxItem Content="HKCU"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Key Path" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="FormKeyPath" Style="{StaticResource MonoTextInputStyle}"
                                                />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Value Name" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="FormValueName" Style="{StaticResource MonoTextInputStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="3">
                                        <TextBlock Text="Type" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FormType" Style="{StaticResource ComboBoxStyle}">
                                            <ComboBoxItem Content="REG_SZ" IsSelected="True"/>
                                            <ComboBoxItem Content="REG_DWORD"/>
                                            <ComboBoxItem Content="REG_QWORD"/>
                                            <ComboBoxItem Content="REG_BINARY"/>
                                            <ComboBoxItem Content="REG_MULTI_SZ"/>
                                            <ComboBoxItem Content="REG_EXPAND_SZ"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Row 2: Data | Operation | Buttons -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,8,0">
                                        <TextBlock Text="Data" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="FormData" Style="{StaticResource MonoTextInputStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Operation" Foreground="{DynamicResource FG2Brush}" FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FormOperation" Style="{StaticResource ComboBoxStyle}">
                                            <ComboBoxItem Content="SET" IsSelected="True"/>
                                            <ComboBoxItem Content="DELETE"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="3" VerticalAlignment="Bottom">
                                        <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                                                Click="FormSave_Click" Margin="0,0,0,4"/>
                                        <Button Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                                                Click="FormCancel_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Dynamic custom entries list -->
                        <StackPanel x:Name="CustomEntriesPanel"/>

                        <!-- Empty hint -->
                        <TextBlock x:Name="NoEntriesHint"
                                   Text="No custom entries added. Click '+ Add Entry' to define a registry key/value."
                                   Foreground="{DynamicResource FG3Brush}" FontSize="12" FontStyle="Italic"/>

                        <!-- Supported types legend -->
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="SUPPORTED VALUE TYPES" Foreground="{DynamicResource FG2Brush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <WrapPanel h:PanelSpacing.Spacing="8">
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_SZ"/>
                                    </Border>
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_DWORD"/>
                                    </Border>
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_QWORD"/>
                                    </Border>
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_BINARY"/>
                                    </Border>
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_MULTI_SZ"/>
                                    </Border>
                                    <Border Style="{StaticResource TagStyle}">
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource FG1Brush}" Text="REG_EXPAND_SZ"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Import .reg File -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Import .reg File" Style="{StaticResource CardTitleText}" Margin="0,0,0,16"/>
                        <Border Style="{StaticResource DropZoneStyle}" Cursor="Hand"
                                MouseLeftButtonDown="ImportReg_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="24,22,24,22" h:PanelSpacing.Spacing="6">
                                <Path Style="{StaticResource IconPath}" Width="24" Height="24"
                                      Data="{StaticResource FileIcon}" Stroke="{DynamicResource FG2Brush}"
                                      HorizontalAlignment="Center"/>
                                <TextBlock Text="Drop .reg file here or click to browse"
                                           Foreground="{DynamicResource FG1Brush}" FontSize="13"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Standard Windows Registry Editor format (.reg)"
                                           Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource BG3Brush}" CornerRadius="6"
                                Padding="14,10" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" h:PanelSpacing.Spacing="10">
                                <Path Style="{StaticResource IconPath}" Width="16" Height="16"
                                      Data="{StaticResource ShieldIcon}" Stroke="{DynamicResource InfoBrush}"/>
                                <TextBlock Foreground="{DynamicResource FG2Brush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center">
                                    <Run Text="Imported .reg files are parsed and validated before injection. "/>
                                    <Run Text="Only "/>
                                    <Run FontFamily="Consolas" Foreground="{DynamicResource FG1Brush}" Text="HKLM"/>
                                    <Run Text=" and "/>
                                    <Run FontFamily="Consolas" Foreground="{DynamicResource FG1Brush}" Text="HKCU"/>
                                    <Run Text=" keys are supported for offline image injection."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Height="24"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Nav -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                Padding="40,16" Background="{DynamicResource BG1Brush}">
            <Grid>
                <Button Content="← Back" Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Left" Click="Back_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:PanelSpacing.Spacing="12">
                    <TextBlock Text="Step 5 of 8" Foreground="{DynamicResource FG2Brush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button Content="Continue →" Style="{StaticResource PrimaryButtonStyle}"
                            Click="Continue_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

