<Window x:Class="GoldenISOBuilder.Views.InAppToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        Width="340" Height="76"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Border x:Name="Card"
            Background="{DynamicResource BG1Brush}"
            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
            CornerRadius="8" Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Color="#000000" Opacity="0.35"/>
        </Border.Effect>

        <Grid>
            <!-- Accent stripe on the left -->
            <Border x:Name="Stripe" Width="4" HorizontalAlignment="Left"
                    CornerRadius="8,0,0,8" Margin="0"/>

            <!-- Content -->
            <StackPanel Margin="18,12,12,12">
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource FG0Brush}"
                           FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="BodyText"
                           Foreground="{DynamicResource FG2Brush}"
                           FontSize="11" Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
