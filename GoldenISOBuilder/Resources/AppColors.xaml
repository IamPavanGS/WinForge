<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         ARCTIC NIGHT — Deep navy + royal blue accent
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Background scale -->
    <Color x:Key="BG0Color">#070E1C</Color>
    <Color x:Key="BG1Color">#0C1829</Color>
    <Color x:Key="BG2Color">#112035</Color>
    <Color x:Key="BG3Color">#172B46</Color>
    <Color x:Key="BG4Color">#1D3558</Color>
    <Color x:Key="LineColor">#1E3560</Color>
    <Color x:Key="LineSoftColor">#142C4A</Color>

    <!-- Foreground scale -->
    <Color x:Key="FG0Color">#ECF0FB</Color>
    <Color x:Key="FG1Color">#BFC8E0</Color>
    <Color x:Key="FG2Color">#8494B8</Color>
    <Color x:Key="FG3Color">#546080</Color>

    <!-- Royal blue accent (replaces gold) -->
    <Color x:Key="Gold1Color">#4D8EF8</Color>
    <Color x:Key="Gold2Color">#6FA4FA</Color>
    <Color x:Key="Gold3Color">#2C6ADA</Color>
    <Color x:Key="GoldGlowColor">#334D8EF8</Color>

    <!-- Status -->
    <Color x:Key="OkColor">#27C48A</Color>
    <Color x:Key="WarnColor">#F59E0B</Color>
    <Color x:Key="ErrColor">#F05260</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>

    <!-- ════════════════════════════════════════════════════════════════
         Per-step accent palette. All hues sit in the same lightness band
         (~65-70%) and saturation band (~55-60%) as Gold1Color so they
         read as siblings of the royal-blue primary, not as competing
         imports. Used ONLY on the page-header icon + a soft background
         badge; card/expander icons keep Gold1Brush for restraint.
         ════════════════════════════════════════════════════════════════ -->
    <Color x:Key="SourceAccentColor">#5DB6E8</Color>   <!-- sky cyan   - Step 1 Source/Output -->
    <Color x:Key="AssetsAccentColor">#4FC2A8</Color>   <!-- soft teal  - Step 2 Assets -->
    <Color x:Key="CustomAccentColor">#9886EE</Color>   <!-- soft violet- Step 3 Customizations -->
    <Color x:Key="AdminAccentColor">#F19A6B</Color>    <!-- warm coral - Step 4 Admin -->
    <Color x:Key="RegistryAccentColor">#D38CD9</Color> <!-- soft mauve - Step Registry -->
    <Color x:Key="ReviewAccentColor">#4FD0CB</Color>   <!-- cyan teal  - Step 5 Review -->
    <Color x:Key="BuildAccentColor">#F0B568</Color>    <!-- warm amber - Step 6 Build -->
    <Color x:Key="TestVmAccentColor">#6FCE93</Color>   <!-- soft sage  - Test in VM -->
    <!-- StepAdvanced intentionally reuses Gold1Color (royal blue) for visual contrast. -->

    <!-- Solid brushes -->
    <SolidColorBrush x:Key="BG0Brush"      Color="{StaticResource BG0Color}"/>
    <SolidColorBrush x:Key="BG1Brush"      Color="{StaticResource BG1Color}"/>
    <SolidColorBrush x:Key="BG2Brush"      Color="{StaticResource BG2Color}"/>
    <SolidColorBrush x:Key="BG3Brush"      Color="{StaticResource BG3Color}"/>
    <SolidColorBrush x:Key="BG4Brush"      Color="{StaticResource BG4Color}"/>
    <SolidColorBrush x:Key="LineBrush"     Color="{StaticResource LineColor}"/>
    <SolidColorBrush x:Key="LineSoftBrush" Color="{StaticResource LineSoftColor}"/>
    <SolidColorBrush x:Key="FG0Brush"      Color="{StaticResource FG0Color}"/>
    <SolidColorBrush x:Key="FG1Brush"      Color="{StaticResource FG1Color}"/>
    <SolidColorBrush x:Key="FG2Brush"      Color="{StaticResource FG2Color}"/>
    <SolidColorBrush x:Key="FG3Brush"      Color="{StaticResource FG3Color}"/>
    <SolidColorBrush x:Key="Gold1Brush"    Color="{StaticResource Gold1Color}"/>
    <SolidColorBrush x:Key="Gold2Brush"    Color="{StaticResource Gold2Color}"/>
    <SolidColorBrush x:Key="Gold3Brush"    Color="{StaticResource Gold3Color}"/>
    <SolidColorBrush x:Key="GoldGlowBrush" Color="{StaticResource GoldGlowColor}"/>
    <SolidColorBrush x:Key="OkBrush"       Color="{StaticResource OkColor}"/>
    <SolidColorBrush x:Key="WarnBrush"     Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="ErrBrush"      Color="{StaticResource ErrColor}"/>
    <SolidColorBrush x:Key="InfoBrush"     Color="{StaticResource InfoColor}"/>

    <!-- Per-step accent solid brushes (used as icon stroke) -->
    <SolidColorBrush x:Key="SourceAccentBrush"   Color="{StaticResource SourceAccentColor}"/>
    <SolidColorBrush x:Key="AssetsAccentBrush"   Color="{StaticResource AssetsAccentColor}"/>
    <SolidColorBrush x:Key="CustomAccentBrush"   Color="{StaticResource CustomAccentColor}"/>
    <SolidColorBrush x:Key="AdminAccentBrush"    Color="{StaticResource AdminAccentColor}"/>
    <SolidColorBrush x:Key="RegistryAccentBrush" Color="{StaticResource RegistryAccentColor}"/>
    <SolidColorBrush x:Key="ReviewAccentBrush"   Color="{StaticResource ReviewAccentColor}"/>
    <SolidColorBrush x:Key="BuildAccentBrush"    Color="{StaticResource BuildAccentColor}"/>
    <SolidColorBrush x:Key="TestVmAccentBrush"   Color="{StaticResource TestVmAccentColor}"/>

    <!-- Per-step soft-tint background brushes for the header icon "chip"
         badge. 18% alpha (0x2E) over deep navy background reads as a
         subtle wash, never loud. -->
    <SolidColorBrush x:Key="SourceAccentBgBrush"   Color="#2E5DB6E8"/>
    <SolidColorBrush x:Key="AssetsAccentBgBrush"   Color="#2E4FC2A8"/>
    <SolidColorBrush x:Key="CustomAccentBgBrush"   Color="#2E9886EE"/>
    <SolidColorBrush x:Key="AdminAccentBgBrush"    Color="#2EF19A6B"/>
    <SolidColorBrush x:Key="RegistryAccentBgBrush" Color="#2ED38CD9"/>
    <SolidColorBrush x:Key="AdvancedAccentBgBrush" Color="#2E4D8EF8"/>
    <SolidColorBrush x:Key="ReviewAccentBgBrush"   Color="#2E4FD0CB"/>
    <SolidColorBrush x:Key="BuildAccentBgBrush"    Color="#2EF0B568"/>
    <SolidColorBrush x:Key="TestVmAccentBgBrush"   Color="#2E6FCE93"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumbBrush"      Color="#2A4060"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#3A5880"/>

    <!-- Status pill brushes -->
    <SolidColorBrush x:Key="OkPillBgBrush"     Color="#0D3028"/>
    <SolidColorBrush x:Key="OkPillLineBrush"   Color="#1A5A48"/>
    <SolidColorBrush x:Key="ErrPillBgBrush"    Color="#3A1010"/>
    <SolidColorBrush x:Key="ErrPillLineBrush"  Color="#6B2020"/>
    <SolidColorBrush x:Key="WarnPillBgBrush"   Color="#38280A"/>
    <SolidColorBrush x:Key="WarnPillLineBrush" Color="#6A5010"/>
    <SolidColorBrush x:Key="InfoPillBgBrush"   Color="#0A1838"/>
    <SolidColorBrush x:Key="InfoPillLineBrush" Color="#1A3A6E"/>

    <!-- Row hover / interactive element tint -->
    <SolidColorBrush x:Key="RowHoverBgBrush"   Color="#142644"/>

    <!-- Page-specific gradients -->
    <LinearGradientBrush x:Key="HeroCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#122040" Offset="0"/>
        <GradientStop Color="#0D1A35" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NewBuildTileBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A3065" Offset="0"/>
        <GradientStop Color="#102048" Offset="1"/>
    </LinearGradientBrush>

    <!-- Gradient accent brushes -->
    <LinearGradientBrush x:Key="GoldGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Gold2Color}" Offset="0"/>
        <GradientStop Color="{StaticResource Gold1Color}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GoldProgressBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Gold3Color}" Offset="0"/>
        <GradientStop Color="{StaticResource Gold1Color}" Offset="0.5"/>
        <GradientStop Color="{StaticResource Gold2Color}" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
