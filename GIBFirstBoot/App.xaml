<Application x:Class="GIBFirstBoot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Core colours -->
        <Color x:Key="BG0">#0F1015</Color>
        <Color x:Key="BG1">#171921</Color>
        <Color x:Key="BG2">#1E2028</Color>
        <Color x:Key="BG3">#252830</Color>
        <Color x:Key="Gold1">#C9A84C</Color>
        <Color x:Key="Gold2">#DABC54</Color>
        <Color x:Key="OkGreen">#5DC873</Color>
        <Color x:Key="ErrRed">#D44840</Color>
        <Color x:Key="FG0">#F4F5FC</Color>
        <Color x:Key="FG1">#CDCFDC</Color>
        <Color x:Key="FG2">#9698A8</Color>
        <Color x:Key="FG3">#6A6C7A</Color>
        <Color x:Key="LineC">#353748</Color>

        <SolidColorBrush x:Key="BG0Brush"   Color="{StaticResource BG0}"/>
        <SolidColorBrush x:Key="BG1Brush"   Color="{StaticResource BG1}"/>
        <SolidColorBrush x:Key="BG2Brush"   Color="{StaticResource BG2}"/>
        <SolidColorBrush x:Key="BG3Brush"   Color="{StaticResource BG3}"/>
        <SolidColorBrush x:Key="Gold1Brush" Color="{StaticResource Gold1}"/>
        <SolidColorBrush x:Key="OkBrush"    Color="{StaticResource OkGreen}"/>
        <SolidColorBrush x:Key="ErrBrush"   Color="{StaticResource ErrRed}"/>
        <SolidColorBrush x:Key="FG0Brush"   Color="{StaticResource FG0}"/>
        <SolidColorBrush x:Key="FG1Brush"   Color="{StaticResource FG1}"/>
        <SolidColorBrush x:Key="FG2Brush"   Color="{StaticResource FG2}"/>
        <SolidColorBrush x:Key="FG3Brush"   Color="{StaticResource FG3}"/>
        <SolidColorBrush x:Key="LineBrush"  Color="{StaticResource LineC}"/>

        <LinearGradientBrush x:Key="GoldGrad" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource Gold1}" Offset="0"/>
            <GradientStop Color="{StaticResource Gold2}" Offset="1"/>
        </LinearGradientBrush>

        <!-- ── Modern thin scrollbar ──────────────────────────────────────────
             No x:Key = applies globally; MainWindow.xaml needs no changes.
             Thumb is 6 px wide, rounded, dark-grey translucent.
             Hover brightens the thumb; drag tints it gold.
             Arrow buttons are replaced with zero-opacity page-scroll buttons
             so track-clicking (page up/down) still works.                  -->

        <!-- Page-area repeat buttons: invisible but hit-testable for track-click -->
        <Style x:Key="SbPageBtn" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"             Value="False"/>
            <Setter Property="Focusable"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thumb: rounded pill, hover + drag colour states -->
        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" CornerRadius="3" Background="#55707888"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#90909EAE"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Gold1Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global ScrollBar override — vertical (default) + horizontal trigger -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle"  Value="True"/>
            <Setter Property="SnapsToDevicePixels"    Value="True"/>
            <Setter Property="Width"                  Value="6"/>
            <Setter Property="MinWidth"               Value="6"/>
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0,3">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SbPageBtn}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}" MinHeight="24"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SbPageBtn}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal variant -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Width"     Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Height="6">
                                    <Track x:Name="PART_Track" Margin="3,0">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource SbPageBtn}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource SbThumb}" MinWidth="24"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource SbPageBtn}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Progress bar style -->
        <Style x:Key="GoldBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource BG3Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource GoldGrad}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <!-- ClipToBounds stops the indeterminate chunk sliding outside the bar -->
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3" Background="Transparent"/>
                            <!-- Width="80" gives the travelling chunk a fixed size for indeterminate mode.
                                 RenderTransform is required for the TranslateX animation. -->
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="3"
                                    Width="80" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PART_Indicator"
                                                             Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"
                                                             From="-100" To="400" Duration="0:0:1.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
